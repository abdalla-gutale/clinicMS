@{
    ViewData["Title"] = "Registration";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Patient Registration";
}

@section styles {
<style>

.gp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.gp-title { font-size:1.25rem; font-weight:800; color:#1e293b; margin:0; }
.gp-sub { font-size:.82rem; color:#64748b; margin:3px 0 0; }
.gp-card { background:#fff; border-radius:16px; border:1px solid #e2e8f0; box-shadow:0 2px 12px rgba(15,23,42,.06); padding:20px; }
.gp-filters { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; align-items:center; }
.gp-search { position:relative; flex:1; min-width:220px; }
.gp-search input { width:100%; height:38px; padding:0 12px 0 38px; border-radius:10px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:.875rem; outline:none; transition:border-color .18s; }
.gp-search input:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); background:#fff; }
.gp-search i { position:absolute; left:11px; top:50%; transform:translateY(-50%); color:#94a3b8; }
.gp-select { height:38px; padding:0 10px; border-radius:10px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:.875rem; outline:none; color:#475569; }
.gp-select:focus { border-color:#0d9488; }
.gp-table { width:100%; border-collapse:collapse; }
.gp-table thead th { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; background:#f8fafc; border-bottom:2px solid #f1f5f9; padding:10px 14px; white-space:nowrap; }
.gp-table tbody td { padding:12px 14px; border-bottom:1px solid #f8fafc; font-size:.875rem; color:#334155; vertical-align:middle; }
.gp-table tbody tr:hover td { background:#f8fafc; }
.gp-table tbody tr:last-child td { border-bottom:none; }
.gp-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:999px; font-size:.7rem; font-weight:700; }
.gp-badge-blue { background:#dbeafe; color:#1d4ed8; }
.gp-badge-pink { background:#fce7f3; color:#be185d; }
.gp-badge-gray { background:#f1f5f9; color:#475569; }
.gp-btn-icon { width:32px; height:32px; border-radius:8px; border:none; display:inline-flex; align-items:center; justify-content:center; font-size:.9rem; cursor:pointer; transition:all .15s; }
.gp-btn-edit { background:#f0fdfa; color:#0d9488; }
.gp-btn-edit:hover { background:#0d9488; color:#fff; }
.gp-btn-delete { background:#fef2f2; color:#dc2626; }
.gp-btn-delete:hover { background:#dc2626; color:#fff; }
.gp-pagination { display:flex; align-items:center; justify-content:space-between; margin-top:16px; flex-wrap:wrap; gap:10px; }
.gp-page-info { font-size:.78rem; color:#64748b; }
.gp-page-btns { display:flex; gap:4px; }
.gp-page-btn { width:32px; height:32px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; color:#475569; font-size:.78rem; font-weight:600; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:all .15s; }
.gp-page-btn.active, .gp-page-btn:hover { border-color:#0d9488; background:#0d9488; color:#fff; }
.gp-avatar { width:36px; height:36px; border-radius:50%; object-fit:cover; background:#f1f5f9; display:inline-flex; align-items:center; justify-content:center; color:#94a3b8; font-size:1rem; flex-shrink:0; }
.modal-content { border-radius:20px; border:none; }
.modal-header { background:#f8fafc; border-radius:20px 20px 0 0; border-bottom:1px solid #f1f5f9; padding:18px 24px; }
.modal-title { font-weight:800; color:#1e293b; font-size:1rem; }
.modal-body { padding:24px; }
.modal-footer { border-top:1px solid #f1f5f9; padding:16px 24px; }
.form-label { font-size:.8rem; font-weight:700; color:#475569; margin-bottom:5px; }
.form-control, .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.875rem; padding:8px 12px; }
.form-control:focus, .form-select:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }
.form-control[readonly] { background:#f8fafc; color:#64748b; }

.pt-photo-upload {
    width: 76px; height: 76px; border-radius: 50%;
    background: #f8fafc; border: 2px dashed #cbd5e1;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; overflow: hidden; transition: border-color .18s, background .18s; flex-shrink: 0;
}
.pt-photo-upload:hover { border-color: #0d9488; background: #f0fdfa; }
.pt-photo-upload img { width:100%; height:100%; object-fit:cover; display:none; }
.pt-photo-upload i { font-size: 1.4rem; color: #94a3b8; }
</style>
}

<div class="gp-page">
    <div class="gp-header">
        <div>
            <h4 class="gp-title">Registration</h4>
            <p class="gp-sub">Register and manage patient records</p>
        </div>
        <button class="btn btn-sm px-3 py-2 fw-700 text-white" style="background:#0d9488;border-radius:10px;" onclick="openModal()">
            <i class="ri-user-add-line me-1"></i> Add Patient
        </button>
    </div>

    <div class="gp-card">
        <div class="gp-filters">
            <div class="gp-search">
                <i class="ri-search-line"></i>
                <input type="text" id="searchInput" placeholder="Search patients..." oninput="handleSearch(this.value)">
            </div>
            <select class="gp-select" id="genderFilter" onchange="handleFilter()">
                <option value="">All Genders</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div style="overflow-x:auto;">
            <table class="gp-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Photo</th>
                        <th>Full Name</th>
                        <th>Gender</th>
                        <th>Date of Birth</th>
                        <th>Age</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="patientsTableBody"></tbody>
            </table>
        </div>
        <div class="gp-pagination">
            <span class="gp-page-info" id="pageInfo"></span>
            <div class="gp-page-btns" id="pageBtns"></div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="patientModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 d-flex align-items-center gap-3">
                        <div class="pt-photo-upload" onclick="document.getElementById('fImageInput').click()">
                            <img id="fImagePreview">
                            <i class="ri-camera-line" id="fImageIcon"></i>
                        </div>
                        <input type="file" id="fImageInput" accept="image/*" style="display:none;" onchange="previewPhoto(this)">
                        <div style="font-size:.72rem;color:#94a3b8;">Patient photo (optional)</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label required">Full Name</label>
                        <input type="text" class="form-control" id="fFullName" placeholder="Full name">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Gender</label>
                        <select class="form-select" id="fGender">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label class="form-label required">Age</label>
                        <input type="text" inputmode="numeric" autocomplete="off" class="form-control" id="fAge" placeholder="Age" maxlength="3"
                               onkeypress="return isAgeKeyAllowed(event)" onpaste="return isAgePasteAllowed(event)" oninput="sanitizeAge(this)">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label required">Phone</label>
                        <input type="tel" inputmode="tel" autocomplete="off" class="form-control" id="fPhone"
                               onkeypress="return isPhoneKeyAllowed(event)" onpaste="return isPhonePasteAllowed(event)" oninput="sanitizePhone(this)">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" autocomplete="off" class="form-control" id="fEmail" oninput="sanitizeEmail(this)">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white px-4" style="background:#0d9488;border-radius:10px;" onclick="savePatient()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var PATIENTS_PAGE_DATA = @Html.Raw(ViewBag.PatientsPageJson);
</script>
<script src="~/scripts/Features/patients.js"></script>
}
