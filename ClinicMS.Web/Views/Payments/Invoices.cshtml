@{
    ViewData["Title"] = "Invoices";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Invoices";
}

@section styles {
<style>
    
.gp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.gp-title { font-size:1.25rem; font-weight:800; color:#1e293b; margin:0; }
.gp-sub { font-size:.82rem; color:#64748b; margin:3px 0 0; }
.gp-card { background:#fff; border-radius:16px; border:1px solid #e2e8f0; box-shadow:0 2px 12px rgba(15,23,42,.06); padding:20px; }
.gp-filters { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; align-items:center; }
.gp-search { position:relative; flex:1; min-width:220px; }
.gp-search input { width:100%; height:38px; padding:0 12px 0 38px; border-radius:10px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:.875rem; outline:none; }
.gp-search input:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }
.gp-search i { position:absolute; left:11px; top:50%; transform:translateY(-50%); color:#94a3b8; }
.gp-table { width:100%; border-collapse:collapse; }
.gp-table thead th { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; background:#f8fafc; border-bottom:2px solid #f1f5f9; padding:10px 14px; white-space:nowrap; }
.gp-table tbody td { padding:12px 14px; border-bottom:1px solid #f8fafc; font-size:.875rem; color:#334155; vertical-align:middle; }
.gp-table tbody tr:hover td { background:#f8fafc; }
.gp-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:999px; font-size:.7rem; font-weight:700; }
.gp-badge-green { background:#dcfce7; color:#15803d; }
.gp-badge-yellow { background:#fef9c3; color:#a16207; }
.gp-badge-red { background:#fee2e2; color:#b91c1c; }
.gp-badge-blue { background:#dbeafe; color:#1d4ed8; }
.gp-btn-icon { width:32px; height:32px; border-radius:8px; border:none; display:inline-flex; align-items:center; justify-content:center; font-size:.9rem; cursor:pointer; transition:all .15s; }
.gp-btn-view { background:#eff6ff; color:#2563eb; }
.gp-btn-view:hover { background:#2563eb; color:#fff; }
.gp-btn-print { background:#f0fdfa; color:#0d9488; }
.gp-btn-print:hover { background:#0d9488; color:#fff; }
.gp-pagination { display:flex; align-items:center; justify-content:space-between; margin-top:16px; flex-wrap:wrap; gap:10px; }
.gp-page-info { font-size:.78rem; color:#64748b; }
.gp-page-btns { display:flex; gap:4px; }
.gp-page-btn { width:32px; height:32px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; color:#475569; font-size:.78rem; font-weight:600; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; }
.gp-page-btn.active, .gp-page-btn:hover { border-color:#0d9488; background:#0d9488; color:#fff; }
.modal-content { border-radius:20px; border:none; }
.modal-header { background:#f8fafc; border-radius:20px 20px 0 0; border-bottom:1px solid #f1f5f9; padding:18px 24px; }
.modal-title { font-weight:800; color:#1e293b; font-size:1rem; }
.modal-body { padding:24px; }
.modal-footer { border-top:1px solid #f1f5f9; padding:16px 24px; }
/* Invoice print styles */
.invoice-print { font-family: 'Segoe UI', sans-serif; }
.invoice-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; padding-bottom:16px; border-bottom:2px solid #0d9488; }
.invoice-brand { font-size:1.5rem; font-weight:900; color:#0d9488; }
.invoice-brand span { display:block; font-size:.75rem; font-weight:500; color:#64748b; }
.invoice-brand-logo { max-height:48px; max-width:220px; object-fit:contain; }
.invoice-no { text-align:right; }
.invoice-no h3 { font-size:1rem; font-weight:800; color:#1e293b; margin:0; }
.invoice-no small { color:#64748b; font-size:.78rem; }
.invoice-parties { display:flex; justify-content:space-between; margin-bottom:20px; }
.invoice-party h6 { font-size:.72rem; font-weight:700; color:#94a3b8; text-transform:uppercase; margin-bottom:6px; }
.invoice-party p { font-size:.875rem; color:#334155; font-weight:600; margin:2px 0; }
.invoice-table { width:100%; border-collapse:collapse; margin-bottom:16px; }
.invoice-table th { font-size:.72rem; font-weight:700; color:#fff; background:#0d9488; padding:8px 12px; }
.invoice-table td { padding:8px 12px; border-bottom:1px solid #f1f5f9; font-size:.875rem; color:#334155; }
.invoice-totals { text-align:right; }
.invoice-totals table { margin-left:auto; }
.invoice-totals td { padding:4px 8px; font-size:.875rem; }
.invoice-totals .total-row td { font-weight:800; font-size:1rem; color:#0d9488; border-top:2px solid #0d9488; }
@@media print { .modal-footer, .btn-close { display:none!important; } }
</style>
}

<div class="gp-page">
    <div class="gp-header">
        <div>
            <h4 class="gp-title">Invoices</h4>
            <p class="gp-sub">Outstanding invoices — view and print details</p>
        </div>
    </div>
    <div class="gp-card">
        <div class="gp-filters">
            <div class="gp-search">
                <i class="ri-search-line"></i>
                <input type="text" id="searchInput" placeholder="Search invoices..." oninput="handleSearch(this.value)">
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table class="gp-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Invoice #</th>
                        <th>Patient</th>
                        <th>Net Amount</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th>Invoice Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="invoicesTableBody"></tbody>
            </table>
        </div>
        <div class="gp-pagination">
            <span class="gp-page-info" id="pageInfo"></span>
            <div class="gp-page-btns" id="pageBtns"></div>
        </div>
    </div>
</div>

<!-- View Invoice Modal -->
<div class="modal fade" id="invoiceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Invoice Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="invoicePrintArea">
                <!-- Filled by JS -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn text-white px-4" style="background:#0d9488;border-radius:10px;" onclick="window.print()">
                    <i class="ri-printer-line me-1"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var OUTSTANDING_DATA = @Html.Raw(ViewBag.OutstandingJson);
    var REPORT_LOGO_URL = @Html.Raw(ViewBag.ReportLogoUrl is not null ? $"\"{ViewBag.ReportLogoUrl}\"" : "null");
    var REPORT_CLINIC_NAME = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)ViewBag.ClinicName));
</script>
<script src="~/scripts/Features/invoices.js"></script>
}
