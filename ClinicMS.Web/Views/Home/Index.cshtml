@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Dashboard";
    ViewBag.pageTitle = "Home";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

@section styles {
<style>
:root {
    --gym-bg:       #f4f6f9;
    --gym-surface:  #ffffff;
    --gym-surface2: #f8fafc;
    --gym-border:   #e2e8f0;
    --gym-fire:     #0d9488;
    --gym-fire2:    #14b8a6;
    --gym-gold:     #f59e0b;
    --gym-green:    #16a34a;
    --gym-blue:     #2563eb;
    --gym-purple:   #7c3aed;
    --gym-text:     #1e293b;
    --gym-muted:    #64748b;
    --gym-subtle:   #cbd5e1;
}

.gym { font-family: 'Inter', sans-serif; background: var(--gym-bg); min-height: 100vh; padding-bottom: 48px; color: var(--gym-text); }

/* ── KPI CARDS ── */
.gym-kpi-row { position:relative; z-index:2; padding: 0 8px; }
.gym-kpi-card {
    background: var(--gym-surface);
    border: 1px solid var(--gym-border);
    border-radius: 20px;
    padding: 22px 20px 18px;
    height: 100%;
    position: relative; overflow: hidden;
    transition: transform .18s, box-shadow .18s;
}
.gym-kpi-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15,23,42,.12); }
.gym-kpi-card::after {
    content:""; position:absolute; top:0; left:0; right:0; height:2px;
    border-radius: 20px 20px 0 0;
}
.gym-kpi-card.c-fire::after  { background: linear-gradient(90deg,#0d9488,#14b8a6); }
.gym-kpi-card.c-gold::after  { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
.gym-kpi-card.c-green::after { background: linear-gradient(90deg,#22c55e,#4ade80); }
.gym-kpi-card.c-blue::after  { background: linear-gradient(90deg,#3b82f6,#60a5fa); }
.gym-kpi-card.c-purple::after{ background: linear-gradient(90deg,#a855f7,#c084fc); }

.gym-kpi-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.gym-kpi-icon { width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.25rem; }
.gym-kpi-icon.c-fire  { background:rgba(13,148,136,.15);  color:#0d9488; }
.gym-kpi-icon.c-gold  { background:rgba(245,158,11,.15); color:#f59e0b; }
.gym-kpi-icon.c-green { background:rgba(22,163,74,.12);   color:#16a34a; }
.gym-kpi-icon.c-blue  { background:rgba(37,99,235,.12);  color:#2563eb; }
.gym-kpi-icon.c-purple{ background:rgba(124,58,237,.12); color:#7c3aed; }
.gym-kpi-val { font-size:2.2rem; font-weight:900; letter-spacing:-.04em; line-height:1; margin-bottom:4px; }
.gym-kpi-val.c-fire  { color:#0d9488; }
.gym-kpi-val.c-gold  { color:#f59e0b; }
.gym-kpi-val.c-green { color:#16a34a; }
.gym-kpi-val.c-blue  { color:#2563eb; }
.gym-kpi-val.c-purple{ color:#7c3aed; }
.gym-kpi-lbl { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:var(--gym-muted); }
.gym-kpi-foot { margin-top:14px; padding-top:14px; border-top:1px solid var(--gym-border); display:flex; align-items:center; justify-content:space-between; }
.gym-kpi-foot-lbl { font-size:.76rem; color:var(--gym-muted); }
.gym-kpi-foot-val { font-size:.82rem; font-weight:800; color:var(--gym-text); }

/* ── CARDS ── */
.gym-card { background:var(--gym-surface); border:1px solid var(--gym-border); border-radius:20px; padding:24px; height:100%; }
.gym-card-head { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:20px; }
.gym-card-title { font-size:1rem; font-weight:800; color:var(--gym-text); margin:0; letter-spacing:-.015em; }
.gym-card-sub { font-size:.78rem; color:var(--gym-muted); margin:3px 0 0; }

/* ── CHIPS ── */
.gym-chip { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:999px; font-size:.7rem; font-weight:700; white-space:nowrap; flex-shrink:0; }
.gym-chip-fire   { background:rgba(13,148,136,.12);  color:#0f766e;  border:1px solid rgba(13,148,136,.15); }
.gym-chip-gold   { background:rgba(245,158,11,.14); color:#f59e0b;  border:1px solid rgba(245,158,11,.2); }
.gym-chip-green  { background:rgba(22,163,74,.1);   color:#16a34a;  border:1px solid rgba(22,163,74,.2); }
.gym-chip-blue   { background:rgba(37,99,235,.1);   color:#2563eb;  border:1px solid rgba(37,99,235,.2); }
.gym-chip-purple { background:rgba(124,58,237,.1);  color:#7c3aed;  border:1px solid rgba(124,58,237,.2); }
.gym-chip-slate  { background:rgba(100,116,139,.12);color:#94a3b8;  border:1px solid rgba(100,116,139,.2); }

/* ── SECTION LABEL ── */
.gym-section-lbl { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.14em; color:var(--gym-muted); margin-bottom:12px; padding-left:2px; display:flex; align-items:center; gap:10px; }
.gym-section-lbl::after { content:""; flex:1; height:1px; background:var(--gym-border); }

/* ── CHARTS ── */
.gym-chart-lg { position:relative; height:270px; }
.gym-chart-md { position:relative; height:230px; }
.gym-chart-sm { position:relative; height:190px; }

/* ── DONUT ── */
.gym-donut-wrap { position:relative; }
.gym-donut-center { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; pointer-events:none; }
.gym-donut-center .dcv { font-size:1.5rem; font-weight:900; color:var(--gym-text); line-height:1; letter-spacing:-.035em; }
.gym-donut-center .dcl { font-size:.62rem; font-weight:700; color:var(--gym-muted); text-transform:uppercase; letter-spacing:.07em; margin-top:3px; }
.gym-donut-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:14px; justify-content:center; }
.gym-legend-item { display:inline-flex; align-items:center; gap:6px; font-size:.74rem; font-weight:700; color:var(--gym-text); }
.gym-legend-item .dot { width:10px; height:10px; border-radius:3px; flex-shrink:0; }

/* ── TIMELINE ── */
.gym-timeline { display:flex; flex-direction:column; }
.gym-tl-item { display:flex; gap:14px; padding:11px 0; border-bottom:1px solid var(--gym-border); }
.gym-tl-item:last-child { border-bottom:none; }
.gym-tl-dot-col { display:flex; flex-direction:column; align-items:center; flex-shrink:0; padding-top:4px; }
.gym-tl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.gym-tl-line { flex:1; width:1px; background:var(--gym-border); margin-top:4px; }
.gym-tl-item:last-child .gym-tl-line { display:none; }
.gym-tl-title { font-size:.85rem; font-weight:700; color:var(--gym-text); margin-bottom:2px; }
.gym-tl-meta  { font-size:.74rem; color:var(--gym-muted); }

/* ── TABLE ── */
.gym-table { width:100%; border-collapse:collapse; margin:0; }
.gym-table thead th { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--gym-muted); background:var(--gym-surface2); border-bottom:1px solid var(--gym-border); padding:10px 14px; white-space:nowrap; }
.gym-table tbody td { padding:12px 14px; vertical-align:middle; border-bottom:1px solid var(--gym-border); font-size:.86rem; color:var(--gym-text); }
.gym-table tbody tr:last-child td { border-bottom:none; }
.gym-table tbody tr:hover td { background:rgba(15,23,42,.02); }
.gym-entity-name { font-weight:700; color:var(--gym-text); font-size:.88rem; }
.gym-entity-meta { font-size:.75rem; color:var(--gym-muted); margin-top:1px; }
.gym-avatar { width:34px; height:34px; border-radius:10px; display:inline-flex; align-items:center; justify-content:center; font-size:.74rem; font-weight:800; flex-shrink:0; text-transform:uppercase; }
.gym-empty { text-align:center; padding:28px 12px; color:var(--gym-muted); font-size:.85rem; }

/* ── BADGES ── */
.gym-badge { display:inline-flex; align-items:center; padding:4px 10px; border-radius:999px; font-size:.7rem; font-weight:700; }
.gym-badge-fire   { background:rgba(13,148,136,.15);  color:#0f766e; }
.gym-badge-green  { background:rgba(22,163,74,.1);   color:#15803d; }
.gym-badge-gold   { background:rgba(245,158,11,.12); color:#b45309; }
.gym-badge-blue   { background:rgba(37,99,235,.1);   color:#1d4ed8; }
.gym-badge-purple { background:rgba(124,58,237,.1);  color:#6d28d9; }
.gym-badge-red    { background:rgba(220,38,38,.1);   color:#b91c1c; }
.gym-badge-slate  { background:#f1f5f9; color:#475569; }
</style>
}

<div class="gym">

    <!-- ═══════════════════════════ KPI CARDS ═══════════════════════════ -->
    <div class="gym-kpi-row mb-4">
        <div class="row g-3">
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-fire">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-fire"><i class="ri-group-3-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-fire" id="kpiPatients">—</div>
                    <div class="gym-kpi-lbl">Total Patients</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Active cycles</span>
                        <span class="gym-kpi-foot-val" id="kpiActiveCycles">—</span>
                    </div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-gold">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-gold"><i class="ri-money-dollar-circle-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-gold" id="kpiTodayRevenue">—</div>
                    <div class="gym-kpi-lbl">Today's Revenue</div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-green">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-green"><i class="ri-wallet-3-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-green" id="kpiOutstanding">—</div>
                    <div class="gym-kpi-lbl">Outstanding Balance</div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-blue">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-blue"><i class="ri-line-chart-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-blue" id="kpiMonthRevenue">—</div>
                    <div class="gym-kpi-lbl">Monthly Revenue</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Month expenses</span>
                        <span class="gym-kpi-foot-val" id="kpiMonthExpenses">—</span>
                    </div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-purple">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-purple"><i class="ri-alert-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-purple" id="kpiLowStock">—</div>
                    <div class="gym-kpi-lbl">Low Stock Items</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Pending purchase orders</span>
                        <span class="gym-kpi-foot-val" id="kpiPendingPOs">—</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════ ROW 1: Revenue & Expenses ═══════════════════════════ -->
    <div class="gym-section-lbl px-2 mb-2">Revenue &amp; Expenses</div>
    <div class="row g-3 mb-4">
        <div class="col-xl-8">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div>
                        <div class="gym-card-title">Revenue Trend</div>
                        <p class="gym-card-sub">Net revenue, last 14 days</p>
                    </div>
                    <span class="gym-chip gym-chip-fire"><i class="ri-line-chart-line"></i></span>
                </div>
                <div class="gym-chart-lg"><canvas id="revenueChart"></canvas></div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div><div class="gym-card-title" style="font-size:.9rem;">Expense Breakdown</div><p class="gym-card-sub">This month, by category</p></div>
                    <span class="gym-chip gym-chip-gold"><i class="ri-pie-chart-line"></i></span>
                </div>
                <div class="gym-chart-sm gym-donut-wrap mt-2">
                    <canvas id="expenseDonut"></canvas>
                    <div class="gym-donut-center"><div class="dcv" id="expenseDonutTotal">0</div><div class="dcl">Total</div></div>
                </div>
                <div class="gym-donut-legend" id="expenseDonutLegend"></div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════ ROW 2: Operations ═══════════════════════════ -->
    <div class="gym-section-lbl px-2 mb-2">Operations</div>
    <div class="row g-3 mb-4">
        <div class="col-xl-6">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div><div class="gym-card-title">Low Stock Items</div><p class="gym-card-sub">SKUs at or below reorder level</p></div>
                    <span class="gym-chip gym-chip-purple"><i class="ri-alert-line"></i></span>
                </div>
                <div class="table-responsive">
                    <table class="gym-table">
                        <thead><tr><th>SKU</th><th>Product</th><th>Stock</th><th>Reorder Level</th></tr></thead>
                        <tbody id="lowStockBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div><div class="gym-card-title">Today's Patient Sessions</div><p class="gym-card-sub">Scheduled, not yet completed</p></div>
                    <span class="gym-chip gym-chip-green"><i class="ri-calendar-2-line"></i></span>
                </div>
                <div class="table-responsive">
                    <table class="gym-table">
                        <thead><tr><th>Patient</th><th>Plan</th><th>Session</th><th>Status</th></tr></thead>
                        <tbody id="todaySessionsBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════ ROW 3: Activity & Top Patients ═══════════════════════════ -->
    <div class="gym-section-lbl px-2 mb-2">Activity &amp; Top Patients</div>
    <div class="row g-3">
        <div class="col-xl-6">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div><div class="gym-card-title">Recent Activity</div><p class="gym-card-sub">Latest system changes</p></div>
                    <span class="gym-chip gym-chip-blue"><i class="ri-time-line"></i></span>
                </div>
                <div class="gym-timeline" id="recentActivityList"></div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div><div class="gym-card-title">Top Patients This Month</div><p class="gym-card-sub">Ranked by amount paid</p></div>
                    <span class="gym-chip gym-chip-gold"><i class="ri-trophy-line"></i></span>
                </div>
                <div class="table-responsive">
                    <table class="gym-table">
                        <thead><tr><th>#</th><th>Patient</th><th>Paid</th><th>Payments</th></tr></thead>
                        <tbody id="topPatientsBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
    var s = @Html.Raw(ViewBag.DashboardJson);
    if (!s) return;

    var fmt = function (n) { return Math.round(n).toLocaleString(); };
    var esc = function (v) { return (v === null || v === undefined) ? '' : String(v).replace(/[&<>"']/g, function (c) { return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]; }); };
    var initials = function (name) { return (name || '').split(' ').filter(Boolean).slice(0, 2).map(function (p) { return p[0]; }).join('').toUpperCase(); };

    document.getElementById('kpiPatients').textContent = s.patientCount.toLocaleString();
    document.getElementById('kpiActiveCycles').textContent = s.activePatientCycleCount.toLocaleString();
    document.getElementById('kpiTodayRevenue').textContent = fmt(s.todayRevenue);
    document.getElementById('kpiOutstanding').textContent = fmt(s.outstandingBalance);
    document.getElementById('kpiMonthRevenue').textContent = fmt(s.monthRevenue);
    document.getElementById('kpiMonthExpenses').textContent = fmt(s.monthExpenses);
    document.getElementById('kpiLowStock').textContent = s.lowStockProductCount.toLocaleString();
    document.getElementById('kpiPendingPOs').textContent = s.pendingPurchaseOrderCount.toLocaleString();

    // Low stock table
    var lowStockBody = document.getElementById('lowStockBody');
    lowStockBody.innerHTML = s.lowStockItems.length ? s.lowStockItems.map(function (i) {
        return '<tr><td class="gym-entity-name">' + esc(i.skuCode) + '</td><td>' + esc(i.productName) + '</td>'
            + '<td><span class="gym-badge gym-badge-red">' + i.stockQuantity + '</span></td><td>' + i.reorderLevel + '</td></tr>';
    }).join('') : '<tr><td colspan="4" class="gym-empty">Nothing below reorder level</td></tr>';

    // Today's sessions table
    var todayBody = document.getElementById('todaySessionsBody');
    todayBody.innerHTML = s.todaySessions.length ? s.todaySessions.map(function (t) {
        var badge = t.status === 'Pending' ? 'gym-badge-blue' : (t.status === 'Cancelled' ? 'gym-badge-red' : 'gym-badge-slate');
        return '<tr><td class="gym-entity-name">' + esc(t.patientName) + '</td><td class="gym-entity-meta">' + esc(t.planName) + '</td>'
            + '<td>' + esc(t.sessionLabel) + '</td><td><span class="gym-badge ' + badge + '">' + esc(t.status) + '</span></td></tr>';
    }).join('') : '<tr><td colspan="4" class="gym-empty">No sessions scheduled for today</td></tr>';

    // Recent activity timeline
    var dotColors = ['#0d9488', '#f59e0b', '#3b82f6', '#a855f7', '#22c55e', '#64748b'];
    var activityList = document.getElementById('recentActivityList');
    activityList.innerHTML = s.recentActivity.length ? s.recentActivity.map(function (a, i) {
        var when = new Date(a.createdAt);
        var ago = Math.round((Date.now() - when.getTime()) / 60000);
        var agoText = ago < 1 ? 'just now' : ago < 60 ? (ago + ' min ago') : ago < 1440 ? (Math.round(ago / 60) + ' hr ago') : (Math.round(ago / 1440) + 'd ago');
        return '<div class="gym-tl-item"><div class="gym-tl-dot-col"><div class="gym-tl-dot" style="background:' + dotColors[i % dotColors.length] + ';"></div><div class="gym-tl-line"></div></div>'
            + '<div><div class="gym-tl-title">' + esc(a.description) + '</div><div class="gym-tl-meta">' + agoText + '</div></div></div>';
    }).join('') : '<div class="gym-empty">No recent activity recorded</div>';

    // Top patients table
    var topBody = document.getElementById('topPatientsBody');
    topBody.innerHTML = s.topPatients.length ? s.topPatients.map(function (p, i) {
        return '<tr><td>' + (i + 1) + '</td>'
            + '<td><div class="d-flex align-items-center gap-2"><div class="gym-avatar" style="background:rgba(13,148,136,.15);color:#0f766e;">' + esc(initials(p.patientName)) + '</div>'
            + '<div class="gym-entity-name">' + esc(p.patientName) + '</div></div></td>'
            + '<td><strong style="color:#0d9488;">' + fmt(p.totalPaid) + '</strong></td><td>' + p.paymentCount + '</td></tr>';
    }).join('') : '<tr><td colspan="4" class="gym-empty">No payments recorded this month</td></tr>';

    Chart.defaults.color = '#64748b';
    Chart.defaults.borderColor = '#e2e8f0';

    // Revenue trend line chart
    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels: s.revenueTrend.map(function (p) { return new Date(p.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }); }),
            datasets: [{
                label: 'Net Revenue',
                data: s.revenueTrend.map(function (p) { return p.netAmount; }),
                borderColor: '#0d9488', backgroundColor: 'rgba(13,148,136,.10)',
                fill: true, tension: 0.35, pointBackgroundColor: '#0d9488', pointRadius: 3, borderWidth: 2.5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { color: '#64748b' } },
                x: { grid: { display: false }, ticks: { color: '#64748b' } }
            }
        }
    });

    // Expense breakdown donut
    var expenseColors = ['#0d9488', '#f59e0b', '#3b82f6', '#a855f7', '#22c55e', '#ef4444'];
    var expenseTotal = s.expenseBreakdown.reduce(function (a, e) { return a + e.amount; }, 0);
    document.getElementById('expenseDonutTotal').textContent = Math.round(expenseTotal).toLocaleString();
    new Chart(document.getElementById('expenseDonut'), {
        type: 'doughnut',
        data: {
            labels: s.expenseBreakdown.map(function (e) { return e.categoryName; }),
            datasets: [{ data: s.expenseBreakdown.map(function (e) { return e.amount; }), backgroundColor: expenseColors, borderWidth: 0, hoverOffset: 8 }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { display: false } } }
    });
    document.getElementById('expenseDonutLegend').innerHTML = s.expenseBreakdown.length ? s.expenseBreakdown.map(function (e, i) {
        return '<span class="gym-legend-item"><span class="dot" style="background:' + expenseColors[i % expenseColors.length] + ';"></span>' + esc(e.categoryName) + '</span>';
    }).join('') : '<span class="text-muted" style="font-size:.8rem;">No expenses recorded this month</span>';
})();
</script>
<script src="~/assets/js/app.js"></script>
}
