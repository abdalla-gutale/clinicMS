@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Dashboard";
    ViewBag.pageTitle = "Home";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

@section styles {
<style>
:root {
    --gym-bg:       #f4f6f9;
    --gym-surface:  #ffffff;
    --gym-surface2: #f8fafc;
    --gym-border:   #e2e8f0;
    --gym-fire:     #0d9488;
    --gym-fire2:    #14b8a6;
    --gym-gold:     #f59e0b;
    --gym-green:    #16a34a;
    --gym-blue:     #2563eb;
    --gym-purple:   #7c3aed;
    --gym-text:     #1e293b;
    --gym-muted:    #64748b;
    --gym-subtle:   #cbd5e1;
}

.gym { font-family: 'Inter', sans-serif; background: var(--gym-bg); min-height: 100vh; padding-bottom: 48px; color: var(--gym-text); }

/* ── HERO ── */
.gym-hero {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, #f0fdfa 0%, #f0fdf4 50%, #f0f9ff 100%);
    border-bottom: 1px solid var(--gym-border);
    padding: 32px 32px 80px;
}
.gym-hero::before {
    content:""; position:absolute; inset:0;
    background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(13,148,136,.08) 0%, transparent 70%),
                radial-gradient(ellipse 40% 60% at 20% 30%, rgba(8,145,178,.06) 0%, transparent 70%);
    pointer-events:none;
}
.gym-hero-grid {
    content:""; position:absolute; inset:0;
    background-image: linear-gradient(rgba(13,148,136,.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(13,148,136,.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events:none;
}
.gym-hero-content { position:relative; z-index:1; }
.gym-hero-eyebrow { font-size:.7rem; font-weight:800; letter-spacing:.14em; text-transform:uppercase; color:var(--gym-fire); margin-bottom:6px; display:flex; align-items:center; gap:8px; }
.gym-hero-eyebrow::before { content:""; width:20px; height:2px; background:var(--gym-fire); border-radius:1px; }
.gym-hero-title { font-size:1.9rem; font-weight:900; letter-spacing:-.04em; line-height:1.05; margin-bottom:8px; color:#1e293b; }
.gym-hero-title span { background: linear-gradient(90deg, #0d9488, #0891b2); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.gym-hero-sub { font-size:.88rem; color:var(--gym-muted); font-weight:500; margin-bottom:20px; }
.gym-hero-badges { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.gym-hero-badge { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:999px; font-size:.72rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; }
.gym-badge-fire  { background:rgba(13,148,136,.10); border:1px solid rgba(13,148,136,.25); color:#0d9488; }
.gym-badge-gold  { background:rgba(245,158,11,.12); border:1px solid rgba(245,158,11,.25); color:#d97706; }
.gym-badge-green { background:rgba(22,163,74,.12);  border:1px solid rgba(22,163,74,.25);  color:#16a34a; }
.gym-live-dot { width:7px; height:7px; border-radius:50%; background:#22c55e; box-shadow:0 0 0 3px rgba(34,197,94,.3); animation: pulse 2s infinite; }
@@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.45} }

/* ── KPI CARDS ── */
.gym-kpi-row { position:relative; z-index:2; padding: 0 8px; }
.gym-kpi-card {
    background: var(--gym-surface);
    border: 1px solid var(--gym-border);
    border-radius: 20px;
    padding: 22px 20px 18px;
    height: 100%;
    position: relative; overflow: hidden;
    transition: transform .18s, box-shadow .18s;
}
.gym-kpi-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15,23,42,.12); }
.gym-kpi-card::after {
    content:""; position:absolute; top:0; left:0; right:0; height:2px;
    border-radius: 20px 20px 0 0;
}
.gym-kpi-card.c-fire::after  { background: linear-gradient(90deg,#0d9488,#14b8a6); }
.gym-kpi-card.c-gold::after  { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
.gym-kpi-card.c-green::after { background: linear-gradient(90deg,#22c55e,#4ade80); }
.gym-kpi-card.c-blue::after  { background: linear-gradient(90deg,#3b82f6,#60a5fa); }
.gym-kpi-card.c-purple::after{ background: linear-gradient(90deg,#a855f7,#c084fc); }

.gym-kpi-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.gym-kpi-icon { width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.25rem; }
.gym-kpi-icon.c-fire  { background:rgba(13,148,136,.15);  color:#0d9488; }
.gym-kpi-icon.c-gold  { background:rgba(245,158,11,.15); color:#f59e0b; }
.gym-kpi-icon.c-green { background:rgba(22,163,74,.12);   color:#16a34a; }
.gym-kpi-icon.c-blue  { background:rgba(37,99,235,.12);  color:#2563eb; }
.gym-kpi-icon.c-purple{ background:rgba(124,58,237,.12); color:#7c3aed; }
.gym-kpi-trend { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:999px; font-size:.7rem; font-weight:800; }
.gym-trend-up   { background:rgba(34,197,94,.12);  color:#22c55e; }
.gym-trend-down { background:rgba(239,68,68,.12);  color:#ef4444; }
.gym-kpi-val { font-size:2.2rem; font-weight:900; letter-spacing:-.04em; line-height:1; margin-bottom:4px; }
.gym-kpi-val.c-fire  { color:#0d9488; }
.gym-kpi-val.c-gold  { color:#f59e0b; }
.gym-kpi-val.c-green { color:#16a34a; }
.gym-kpi-val.c-blue  { color:#2563eb; }
.gym-kpi-val.c-purple{ color:#7c3aed; }
.gym-kpi-lbl { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:var(--gym-muted); }
.gym-kpi-foot { margin-top:14px; padding-top:14px; border-top:1px solid var(--gym-border); display:flex; align-items:center; justify-content:space-between; }
.gym-kpi-foot-lbl { font-size:.76rem; color:var(--gym-muted); }
.gym-kpi-foot-val { font-size:.82rem; font-weight:800; color:var(--gym-text); }

/* ── CARDS ── */
.gym-card { background:var(--gym-surface); border:1px solid var(--gym-border); border-radius:20px; padding:24px; height:100%; }
.gym-card-head { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:20px; }
.gym-card-title { font-size:1rem; font-weight:800; color:var(--gym-text); margin:0; letter-spacing:-.015em; }
.gym-card-sub { font-size:.78rem; color:var(--gym-muted); margin:3px 0 0; }

/* ── CHIPS ── */
.gym-chip { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:999px; font-size:.7rem; font-weight:700; white-space:nowrap; flex-shrink:0; }
.gym-chip-fire   { background:rgba(13,148,136,.12);  color:#0f766e;  border:1px solid rgba(13,148,136,.15); }
.gym-chip-gold   { background:rgba(245,158,11,.14); color:#f59e0b;  border:1px solid rgba(245,158,11,.2); }
.gym-chip-green  { background:rgba(22,163,74,.1);   color:#16a34a;  border:1px solid rgba(22,163,74,.2); }
.gym-chip-blue   { background:rgba(37,99,235,.1);   color:#2563eb;  border:1px solid rgba(37,99,235,.2); }
.gym-chip-purple { background:rgba(124,58,237,.1);  color:#7c3aed;  border:1px solid rgba(124,58,237,.2); }
.gym-chip-slate  { background:rgba(100,116,139,.12);color:#94a3b8;  border:1px solid rgba(100,116,139,.2); }

/* ── SECTION LABEL ── */
.gym-section-lbl { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.14em; color:var(--gym-muted); margin-bottom:12px; padding-left:2px; display:flex; align-items:center; gap:10px; }
.gym-section-lbl::after { content:""; flex:1; height:1px; background:var(--gym-border); }

/* ── CHARTS ── */
.gym-chart-lg { position:relative; height:270px; }
.gym-chart-md { position:relative; height:230px; }
.gym-chart-sm { position:relative; height:190px; }

/* ── TABS ── */
.gym-tabs { display:flex; gap:3px; background:#f1f5f9; border-radius:10px; padding:4px; flex-shrink:0; }
.gym-tab { padding:5px 14px; border-radius:7px; border:none; background:transparent; font-size:.7rem; font-weight:700; color:var(--gym-muted); cursor:pointer; transition:all .15s; letter-spacing:.04em; text-transform:uppercase; }
.gym-tab.active { background:#fff; color:#0d9488; box-shadow:0 2px 8px rgba(13,148,136,.2); }
.gym-tab:hover:not(.active) { color:var(--gym-text); }

/* ── MINI STATS ── */
.gym-mini-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--gym-border); border-radius:14px; overflow:hidden; margin-top:20px; }
.gym-mini-stat { background:var(--gym-surface); padding:14px 16px; display:flex; align-items:center; gap:12px; }
.gym-ms-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
.gym-ms-val { font-size:1.05rem; font-weight:800; color:var(--gym-text); line-height:1; }
.gym-ms-lbl { font-size:.65rem; font-weight:700; color:var(--gym-muted); margin-top:2px; text-transform:uppercase; letter-spacing:.05em; }

/* ── DONUT ── */
.gym-donut-wrap { position:relative; }
.gym-donut-center { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; pointer-events:none; }
.gym-donut-center .dcv { font-size:1.7rem; font-weight:900; color:var(--gym-text); line-height:1; letter-spacing:-.035em; }
.gym-donut-center .dcl { font-size:.65rem; font-weight:700; color:var(--gym-muted); text-transform:uppercase; letter-spacing:.07em; margin-top:3px; }
.gym-donut-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:14px; justify-content:center; }
.gym-legend-item { display:inline-flex; align-items:center; gap:6px; font-size:.74rem; font-weight:700; color:var(--gym-text); }
.gym-legend-item .dot { width:10px; height:10px; border-radius:3px; flex-shrink:0; }

/* ── PROGRESS ── */
.gym-prog-row { display:flex; align-items:center; gap:14px; padding:10px 0; border-bottom:1px solid var(--gym-border); }
.gym-prog-row:last-child { border-bottom:none; }
.gym-prog-label { flex:1; font-size:.84rem; font-weight:600; color:var(--gym-text); }
.gym-prog-bar-wrap { flex:2; height:7px; background:rgba(255,255,255,.07); border-radius:999px; overflow:hidden; }
.gym-prog-bar { height:100%; border-radius:999px; }
.gym-prog-pct { font-size:.78rem; font-weight:800; color:var(--gym-text); min-width:36px; text-align:right; }

/* ── TIMELINE ── */
.gym-timeline { display:flex; flex-direction:column; }
.gym-tl-item { display:flex; gap:14px; padding:11px 0; border-bottom:1px solid var(--gym-border); }
.gym-tl-item:last-child { border-bottom:none; }
.gym-tl-dot-col { display:flex; flex-direction:column; align-items:center; flex-shrink:0; padding-top:4px; }
.gym-tl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.gym-tl-line { flex:1; width:1px; background:var(--gym-border); margin-top:4px; }
.gym-tl-item:last-child .gym-tl-line { display:none; }
.gym-tl-title { font-size:.85rem; font-weight:700; color:var(--gym-text); margin-bottom:2px; }
.gym-tl-meta  { font-size:.74rem; color:var(--gym-muted); }

/* ── TABLE ── */
.gym-table { width:100%; border-collapse:collapse; margin:0; }
.gym-table thead th { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--gym-muted); background:var(--gym-surface2); border-bottom:1px solid var(--gym-border); padding:10px 14px; white-space:nowrap; }
.gym-table tbody td { padding:12px 14px; vertical-align:middle; border-bottom:1px solid var(--gym-border); font-size:.86rem; color:var(--gym-text); }
.gym-table tbody tr:last-child td { border-bottom:none; }
.gym-table tbody tr:hover td { background:rgba(255,255,255,.025); }
.gym-entity-name { font-weight:700; color:var(--gym-text); font-size:.88rem; }
.gym-entity-meta { font-size:.75rem; color:var(--gym-muted); margin-top:1px; }
.gym-avatar { width:34px; height:34px; border-radius:10px; display:inline-flex; align-items:center; justify-content:center; font-size:.74rem; font-weight:800; flex-shrink:0; text-transform:uppercase; }

/* ── BADGES ── */
.gym-badge { display:inline-flex; align-items:center; padding:4px 10px; border-radius:999px; font-size:.7rem; font-weight:700; }
.gym-badge-fire   { background:rgba(13,148,136,.15);  color:#0f766e; }
.gym-badge-green  { background:rgba(22,163,74,.1);   color:#15803d; }
.gym-badge-gold   { background:rgba(245,158,11,.12); color:#b45309; }
.gym-badge-blue   { background:rgba(37,99,235,.1);   color:#1d4ed8; }
.gym-badge-purple { background:rgba(124,58,237,.1);  color:#6d28d9; }
.gym-badge-red    { background:rgba(220,38,38,.1);   color:#b91c1c; }
.gym-badge-slate  { background:#f1f5f9; color:#475569; }

/* ── RANK MEDAL ── */
.gym-rank { width:28px; height:28px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-size:.72rem; font-weight:900; }
.gym-rank-1 { background:rgba(245,158,11,.2); color:#f59e0b; }
.gym-rank-2 { background:rgba(100,116,139,.15); color:#94a3b8; }
.gym-rank-3 { background:rgba(180,83,9,.15); color:#d97706; }
.gym-rank-n { background:rgba(255,255,255,.05); color:var(--gym-muted); }

/* ── HEAT CELLS (streak grid) ── */
.gym-heat-grid { display:flex; flex-direction:column; gap:3px; }
.gym-heat-row  { display:flex; gap:3px; }
.gym-heat-cell { width:14px; height:14px; border-radius:3px; cursor:default; transition:opacity .1s; }
.gym-heat-cell:hover { opacity:.7; }

/* ── BURNDOWN BAR ── */
.gym-burn-bar-wrap { height:10px; background:rgba(255,255,255,.07); border-radius:999px; overflow:hidden; }
.gym-burn-bar { height:100%; border-radius:999px; background:linear-gradient(90deg,#0d9488,#f59e0b); }
</style>
}

<div class="gym">

    <!-- ═══════════════════════════ KPI CARDS ═══════════════════════════ -->
    <div class="gym-kpi-row mb-4">
        <div class="row g-3">
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-fire">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-fire"><i class="ri-group-3-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-fire" id="kpiPatients">—</div>
                    <div class="gym-kpi-lbl">Total Patients</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Active cycles</span>
                        <span class="gym-kpi-foot-val" id="kpiActiveCycles">—</span>
                    </div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-gold">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-gold"><i class="ri-money-dollar-circle-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-gold" id="kpiTodayRevenue">—</div>
                    <div class="gym-kpi-lbl">Today's Revenue</div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-green">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-green"><i class="ri-wallet-3-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-green" id="kpiOutstanding">—</div>
                    <div class="gym-kpi-lbl">Outstanding Balance</div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-blue">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-blue"><i class="ri-line-chart-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-blue" id="kpiMonthRevenue">—</div>
                    <div class="gym-kpi-lbl">Monthly Revenue</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Month expenses</span>
                        <span class="gym-kpi-foot-val" id="kpiMonthExpenses">—</span>
                    </div>
                </div>
            </div>
            <div class="col-xl col-md-6 col-6">
                <div class="gym-kpi-card c-purple">
                    <div class="gym-kpi-top">
                        <div class="gym-kpi-icon c-purple"><i class="ri-alert-line"></i></div>
                    </div>
                    <div class="gym-kpi-val c-purple" id="kpiLowStock">—</div>
                    <div class="gym-kpi-lbl">Low Stock Items</div>
                    <div class="gym-kpi-foot">
                        <span class="gym-kpi-foot-lbl">Pending purchase orders</span>
                        <span class="gym-kpi-foot-val" id="kpiPendingPOs">—</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════ ROW 1 ═══════════════════════════ -->
    <div class="gym-section-lbl px-2 mb-2">Membership Overview</div>
    <div class="row g-3 mb-4">
        <div class="col-xl-8">
            <div class="gym-card">
                <div class="gym-card-head">
                    <div>
                        <div class="gym-card-title">Check-in Traffic</div>
                        <p class="gym-card-sub">Daily gym visits vs new sign-ups</p>
                    </div>
                    <div class="gym-tabs" id="gymChartTabs">
                        <button class="gym-tab active" data-panel="gymLine">Visits</button>
                        <button class="gym-tab" data-panel="gymBar">By Plan</button>
                    </div>
                </div>
                <div class="gym-chart-lg" id="gymLine"><canvas id="lineChart"></canvas></div>
                <div class="gym-chart-lg" id="gymBar" style="display:none;"><canvas id="barChart"></canvas></div>
                <div class="gym-mini-stats">
                    <div class="gym-mini-stat">
                        <div class="gym-ms-icon" style="background:rgba(13,148,136,.12);"><i class="ri-group-3-line" style="color:#0d9488;"></i></div>
                        <div><div class="gym-ms-val">1,248</div><div class="gym-ms-lbl">Members</div></div>
                    </div>
                    <div class="gym-mini-stat">
                        <div class="gym-ms-icon" style="background:rgba(245,158,11,.14);"><i class="ri-run-line" style="color:#f59e0b;"></i></div>
                        <div><div class="gym-ms-val">142</div><div class="gym-ms-lbl">Today</div></div>
                    </div>
                    <div class="gym-mini-stat">
                        <div class="gym-ms-icon" style="background:rgba(34,197,94,.14);"><i class="ri-user-add-line" style="color:#22c55e;"></i></div>
                        <div><div class="gym-ms-val">+37</div><div class="gym-ms-lbl">New / Mo</div></div>
                    </div>
                    <div class="gym-mini-stat">
                        <div class="gym-ms-icon" style="background:rgba(59,130,246,.14);"><i class="ri-shield-star-line" style="color:#3b82f6;"></i></div>
                        <div><div class="gym-ms-val">88%</div><div class="gym-ms-lbl">Retention</div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="gym-card d-flex flex-column gap-4">
                <div>
                    <div class="gym-card-head mb-0">
                        <div><div class="gym-card-title" style="font-size:.9rem;">Plan Distribution</div><p class="gym-card-sub">Active subscriptions by tier</p></div>
                        <span class="gym-chip gym-chip-fire" style="padding:4px 10px;"><i class="ri-donut-chart-line"></i></span>
                    </div>
                    <div class="gym-chart-sm gym-donut-wrap mt-2">
                        <canvas id="donutPlans"></canvas>
                        <div class="gym-donut-center"><div class="dcv">1,104</div><div class="dcl">Active</div></div>
                    </div>
                    <div class="gym-donut-legend">
                        <span class="gym-legend-item"><span class="dot" style="background:#0d9488;"></span>Elite (284)</span>
                        <span class="gym-legend-item"><span class="dot" style="background:#f59e0b;"></span>Pro (476)</span>
                        <span class="gym-legend-item"><span class="dot" style="background:#3b82f6;"></span>Basic (344)</span>
                    </div>
                </div>
                <hr style="border-color:var(--gym-border);margin:0;">
                <div>
                    <div class="gym-card-head mb-0">
                        <div><div class="gym-card-title" style="font-size:.9rem;">Class Fill Rate</div><p class="gym-card-sub">Booked vs capacity</p></div>
                        <span class="gym-chip gym-chip-gold" style="padding:4px 10px;"><i class="ri-donut-chart-line"></i></span>
                    </div>
                    <div class="gym-chart-sm gym-donut-wrap mt-2">
