@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
    var s = @Html.Raw(ViewBag.DashboardJson);
    if (!s) return;
    var fmt = function (n) { return Math.round(n).toLocaleString(); };
    document.getElementById('kpiPatients').textContent = s.patientCount.toLocaleString();
    document.getElementById('kpiActiveCycles').textContent = s.activePatientCycleCount.toLocaleString();
    document.getElementById('kpiTodayRevenue').textContent = fmt(s.todayRevenue);
    document.getElementById('kpiOutstanding').textContent = fmt(s.outstandingBalance);
    document.getElementById('kpiMonthRevenue').textContent = fmt(s.monthRevenue);
    document.getElementById('kpiMonthExpenses').textContent = fmt(s.monthExpenses);
    document.getElementById('kpiLowStock').textContent = s.lowStockProductCount.toLocaleString();
    document.getElementById('kpiPendingPOs').textContent = s.pendingPurchaseOrderCount.toLocaleString();
})();
</script>
<script>
(function () {
    'use strict';

    const FIRE   = '#0d9488';
    const FIRE2  = '#14b8a6';
    const GOLD   = '#f59e0b';
    const GREEN  = '#16a34a';
    const BLUE   = '#2563eb';
    const BLUE2  = '#3b82f6';
    const PURPLE = '#7c3aed';
    const PURPLE2= '#a855f7';
    const CYAN   = '#0891b2';
    const SLATE  = '#475569';

    Chart.defaults.color = '#64748b';
    Chart.defaults.borderColor = '#e2e8f0';

    /* ── 1. Line — Check-in Traffic ── */
    new Chart(document.getElementById('lineChart'), {
        type: 'line',
        data: {
            labels: ['Jul 1','Jul 3','Jul 5','Jul 7','Jul 9','Jul 11','Jul 13','Jul 15','Jul 17'],
            datasets: [
                { label: 'Check-ins', data: [98,121,134,145,118,162,155,178,142], borderColor: FIRE, backgroundColor: 'rgba(13,148,136,.10)', fill: true, tension: 0.45, pointBackgroundColor: FIRE, pointRadius: 4, borderWidth: 2.5 },
                { label: 'New Members', data: [3,5,4,7,6,9,8,11,6], borderColor: GOLD, backgroundColor: 'rgba(8,145,178,.08)', fill: true, tension: 0.45, borderWidth: 2, pointBackgroundColor: GOLD, pointRadius: 3, yAxisID: 'y2' }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11, weight: '700' }, color: '#94a3b8' } } },
            scales: {
                y:  { beginAtZero: false, grid: { color: '#f1f5f9' }, ticks: { color: '#64748b' } },
                y2: { position: 'right', beginAtZero: true, grid: { display: false }, ticks: { color: '#64748b' } },
                x:  { grid: { display: false }, ticks: { color: '#64748b' } }
            }
        }
    });

    /* ── 2. Bar — By Plan ── */
    new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
            labels: ['Elite','Pro','Basic','Student','Day Pass','Corporate','Senior','Trial'],
            datasets: [
                { label: 'Members', data: [284,476,344,68,42,54,38,44], backgroundColor: FIRE + 'cc', borderRadius: 8 },
                { label: 'Avg Check-ins/mo', data: [22,16,11,13,4,14,9,6], backgroundColor: GOLD + 'cc', borderRadius: 8 }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11, weight: '700' }, color: '#94a3b8' } } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { color: '#64748b' } },
                x: { grid: { display: false }, ticks: { color: '#64748b' } }
            }
        }
    });

    /* ── 3. Donut — Plans ── */
    new Chart(document.getElementById('donutPlans'), {
        type: 'doughnut',
        data: {
            labels: ['Elite','Pro','Basic'],
            datasets: [{ data: [284,476,344], backgroundColor: [FIRE, GOLD, BLUE], borderWidth: 0, hoverOffset: 8 }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { display: false } } }
    });

    /* ── 4. Donut — Class Fill ── */
    new Chart(document.getElementById('donutClasses'), {
        type: 'doughnut',
        data: {
            labels: ['Booked','Open'],
            datasets: [{ data: [133,47], backgroundColor: [GREEN, '#e2e8f0'], borderWidth: 0, hoverOffset: 8 }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { display: false } } }
    });

    /* ── 5. Radar — Trainer Scores ── */
    new Chart(document.getElementById('radarChart'), {
        type: 'radar',
        data: {
            labels: ['HIIT','Yoga','CrossFit','Spin','Nutrition','PT'],
            datasets: [
                { label: 'This Month', data: [92,78,88,84,70,90], borderColor: FIRE, backgroundColor: 'rgba(13,148,136,.18)', borderWidth: 2, pointBackgroundColor: FIRE },
                { label: 'Last Month', data: [80,75,82,78,65,85], borderColor: GOLD, backgroundColor: 'rgba(245,158,11,.10)', borderWidth: 1.5, borderDash: [5,3], pointBackgroundColor: GOLD }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            scales: { r: { grid: { color: '#f1f5f9' }, angleLines: { color: '#f1f5f9' }, ticks: { stepSize: 20, color: '#475569', backdropColor: 'transparent', font: { size: 10 } }, pointLabels: { color: '#94a3b8', font: { size: 11, weight: '700' } } } },
            plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11, weight: '700' }, color: '#94a3b8' } } }
        }
    });

    /* ── 6. Area — Weekly foot traffic ── */
    new Chart(document.getElementById('areaChart'), {
        type: 'bar',
        data: {
            labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
            datasets: [
                { label: 'Morning (6–12)', data: [54,62,48,70,58,82,44], backgroundColor: FIRE + 'bb', borderRadius: 6 },
                { label: 'Afternoon (12–6)', data: [38,44,52,40,46,65,31], backgroundColor: GOLD + 'bb', borderRadius: 6 },
                { label: 'Evening (6–10)', data: [68,74,66,80,72,48,22], backgroundColor: BLUE + 'bb', borderRadius: 6 }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11, weight: '700' }, color: '#94a3b8' } } },
            scales: {
                x: { stacked: true, grid: { display: false }, ticks: { color: '#64748b' } },
                y: { stacked: true, grid: { color: '#f1f5f9' }, ticks: { color: '#64748b' } }
            }
        }
    });

    /* ── 7. Polar — Revenue ── */
    new Chart(document.getElementById('polarChart'), {
        type: 'polarArea',
        data: {
            labels: ['Memberships','PT Sessions','Classes','Supplements','Merchandise'],
            datasets: [{ data: [24000,7200,3800,2100,1300], backgroundColor: [FIRE+'cc', GOLD+'cc', GREEN+'cc', BLUE+'cc', PURPLE+'cc'], borderWidth: 0 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'right', labels: { boxWidth: 12, font: { size: 11, weight: '700' }, color: '#94a3b8' } } },
            scales: { r: { grid: { color: '#f1f5f9' }, ticks: { display: false } } }
        }
    });

    /* ── Tab switching ── */
    document.querySelectorAll('#gymChartTabs .gym-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('#gymChartTabs .gym-tab').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            var p = btn.getAttribute('data-panel');
            document.getElementById('gymLine').style.display = p === 'gymLine' ? 'block' : 'none';
            document.getElementById('gymBar').style.display  = p === 'gymBar'  ? 'block' : 'none';
        });
    });
})();
</script>
<script src="~/assets/js/app.js"></script>
