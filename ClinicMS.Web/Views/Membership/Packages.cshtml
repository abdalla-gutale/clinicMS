@{
    ViewData["Title"] = "Membership Packages";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Membership Packages";
}

@section styles {
<style>
    
.gp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.gp-title { font-size:1.25rem; font-weight:800; color:#1e293b; margin:0; }
.gp-sub { font-size:.82rem; color:#64748b; margin:3px 0 0; }
.pkg-card { background:#fff; border-radius:18px; border:1px solid #e2e8f0; box-shadow:0 2px 12px rgba(15,23,42,.06); padding:24px; position:relative; overflow:hidden; transition:transform .18s, box-shadow .18s; }
.pkg-card:hover { transform:translateY(-3px); box-shadow:0 8px 28px rgba(15,23,42,.12); }
.pkg-card::before { content:""; position:absolute; top:0; left:0; right:0; height:4px; background:linear-gradient(90deg,#0d9488,#2dd4bf); }
.pkg-name { font-size:1rem; font-weight:800; color:#1e293b; margin-bottom:4px; }
.pkg-price { font-size:2rem; font-weight:900; color:#0d9488; line-height:1; margin:12px 0 4px; }
.pkg-price span { font-size:.85rem; font-weight:600; color:#64748b; }
.pkg-meta { display:flex; flex-wrap:wrap; gap:8px; margin:14px 0; }
.pkg-pill { display:inline-flex; align-items:center; gap:4px; padding:4px 12px; border-radius:999px; font-size:.72rem; font-weight:700; background:#f0fdfa; color:#0d9488; }
.pkg-desc { font-size:.82rem; color:#64748b; line-height:1.6; margin-bottom:14px; min-height:40px; }
.pkg-actions { display:flex; gap:8px; }
.pkg-badge { display:inline-flex; padding:3px 10px; border-radius:999px; font-size:.68rem; font-weight:700; position:absolute; top:16px; right:16px; }
.pkg-badge-active { background:#dcfce7; color:#15803d; }
.pkg-badge-inactive { background:#f1f5f9; color:#475569; }
.modal-content { border-radius:20px; border:none; }
.modal-header { background:#f8fafc; border-radius:20px 20px 0 0; border-bottom:1px solid #f1f5f9; padding:18px 24px; }
.modal-title { font-weight:800; color:#1e293b; font-size:1rem; }
.modal-body { padding:24px; }
.modal-footer { border-top:1px solid #f1f5f9; padding:16px 24px; }
.form-label { font-size:.8rem; font-weight:700; color:#475569; margin-bottom:5px; }
.form-control, .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.875rem; padding:8px 12px; }
.form-control:focus, .form-select:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }
</style>
}

<div class="gp-page">
    <div class="gp-header">
        <div>
            <h4 class="gp-title">Membership Packages</h4>
            <p class="gp-sub">Configure subscription plans</p>
        </div>
        <button class="btn btn-sm px-3 py-2 fw-700 text-white" style="background:#0d9488;border-radius:10px;" onclick="openModal()">
            <i class="ri-add-line me-1"></i> Add Package
        </button>
    </div>
    <div class="row g-3" id="packagesGrid"></div>
</div>

<div class="modal fade" id="pkgModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Package</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Package Name</label>
                        <input type="text" class="form-control" id="fName" placeholder="e.g. Pro Monthly">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Price (EGP)</label>
                        <input type="number" class="form-control" id="fPrice" placeholder="0">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Duration (Months)</label>
                        <input type="number" class="form-control" id="fDuration" placeholder="1" min="1">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Visits Per Day (0=Unlimited)</label>
                        <input type="number" class="form-control" id="fVisits" placeholder="0" min="0">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Status</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="fStatus" checked style="width:42px;height:22px;">
                            <label class="form-check-label ms-2" for="fStatus">Active</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="fDesc" rows="3" placeholder="Package description..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white px-4" style="background:#0d9488;border-radius:10px;" onclick="savePackage()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/scripts/Features/packages.js"></script>
}
