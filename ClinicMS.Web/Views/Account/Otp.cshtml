@{
    ViewData["Title"] = "Verify OTP";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section styles {
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

.auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background:
        radial-gradient(circle, #ccfbf1 1px, transparent 1px) 0 0/22px 22px,
        #f0fdfa;
}

.auth-card {
    width: 100%;
    max-width: 1120px;
    min-height: 660px;
    display: flex;
    border-radius: 28px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 30px 80px rgba(15,118,110,.18), 0 8px 24px rgba(15,23,42,.08);
}

/* ── Left panel ── */
.auth-left {
    width: 54%;
    background: linear-gradient(155deg, #0b4a44 0%, #0d9488 45%, #0891b2 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 56px;
    position: relative;
    overflow: hidden;
}
.auth-left::before {
    content: "";
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.auth-left-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: .2;
    pointer-events: none;
}
.auth-left-blob.b1 { width: 320px; height: 320px; background: #ccfbf1; top: -100px; right: -100px; }
.auth-left-blob.b2 { width: 240px; height: 240px; background: #bae6fd; bottom: -80px; left: -60px; }

.auth-brand {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 44px; position: relative; z-index: 1;
}
.auth-brand-icon {
    width: 48px; height: 48px; border-radius: 14px;
    background: rgba(255,255,255,.16); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem; color: #fff; border: 1.5px solid rgba(255,255,255,.28);
    overflow: hidden;
}
.auth-brand-name { font-size: 1.35rem; font-weight: 800; color: #fff; letter-spacing: -.02em; }
.auth-brand-sub  { font-size: .72rem; color: rgba(255,255,255,.62); font-weight: 500; margin-top: 1px; }

.auth-hero { position: relative; z-index: 1; margin-bottom: 40px; }
.auth-hero h2 {
    font-size: 2.15rem; font-weight: 800; color: #fff;
    line-height: 1.18; letter-spacing: -.02em; margin-bottom: 14px;
}
.auth-hero h2 .accent { color: #99f6e4; }
.auth-hero p { font-size: .92rem; color: rgba(255,255,255,.72); line-height: 1.65; max-width: 420px; }
.auth-hero p strong { color: rgba(255,255,255,.92); font-weight: 700; }

.auth-features {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 18px;
    margin-bottom: 32px;
}
.auth-feature { display: flex; align-items: flex-start; gap: 14px; }
.auth-feature-icon {
    width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.15rem;
}
.auth-feature-title { font-size: .88rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
.auth-feature-desc { font-size: .78rem; color: rgba(255,255,255,.62); line-height: 1.5; }

.auth-quote {
    position: relative; z-index: 1;
    display: flex; align-items: flex-start; gap: 12px;
    padding-top: 24px; border-top: 1px solid rgba(255,255,255,.16);
}
.auth-quote-icon {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background: rgba(255,255,255,.16);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: .85rem;
}
.auth-quote-text { font-size: .82rem; color: rgba(255,255,255,.75); line-height: 1.6; font-style: italic; }

/* ── Right panel ── */
.auth-right {
    width: 46%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 56px 48px;
}
.auth-form-wrap { width: 100%; max-width: 380px; }

.auth-form-logo {
    width: 60px; height: 60px; border-radius: 16px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.6rem;
    margin: 0 auto 20px; overflow: hidden;
    box-shadow: 0 10px 24px rgba(13,148,136,.3);
}

.auth-form-title {
    font-size: 1.5rem; font-weight: 800; color: #0f172a;
    letter-spacing: -.02em; margin-bottom: 6px; text-align: center;
}
.auth-form-sub { font-size: .85rem; color: #64748b; margin-bottom: 4px; text-align: center; line-height: 1.5; }
.otp-email { font-weight: 700; color: #0d9488; }

.otp-sent-info {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: #f0fdfa; border: 1.5px solid #a7f3d0; border-radius: 10px;
    padding: 10px 14px; margin: 16px 0 24px;
    font-size: .82rem; color: #0f766e; font-weight: 600;
}
.otp-timer { color: #0d9488; font-weight: 800; }
.otp-timer.danger { color: #ef4444; }

/* OTP boxes */
.otp-inputs { display: flex; gap: 10px; justify-content: center; margin-bottom: 24px; }
.otp-box {
    width: 52px; height: 58px;
    border: 1.5px solid #e2e8f0; border-radius: 12px;
    text-align: center; font-size: 1.35rem; font-weight: 800;
    color: #0f172a; background: #f8fafc; outline: none;
    transition: border-color .15s, box-shadow .15s, background .15s, transform .12s;
    font-family: 'Poppins', sans-serif; caret-color: #0d9488;
}
.otp-box:focus { border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,.12); background: #fff; transform: scale(1.05); }
.otp-box.filled { border-color: #0d9488; background: #f0fdfa; color: #0d9488; }
.otp-box.is-error { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.1); animation: shake .35s; }

@@keyframes shake {
    0%,100%{transform:translateX(0);}
    20%{transform:translateX(-5px);}
    40%{transform:translateX(5px);}
    60%{transform:translateX(-4px);}
    80%{transform:translateX(4px);}
}

.auth-btn {
    width: 100%; height: 50px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    border: none; border-radius: 12px;
    font-size: .95rem; font-weight: 700; color: #fff;
    cursor: pointer; letter-spacing: .02em;
    transition: opacity .15s, transform .12s, box-shadow .15s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Poppins', sans-serif;
    box-shadow: 0 4px 16px rgba(13,148,136,.35);
    margin-bottom: 18px;
}
.auth-btn:hover  { opacity: .92; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(13,148,136,.4); }
.auth-btn:active { transform: translateY(0); }
.auth-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }
.auth-btn.loading .btn-text { display: none; }
.auth-btn.loading::after {
    content: "";
    width: 20px; height: 20px; border-radius: 50%;
    border: 2.5px solid rgba(255,255,255,.4);
    border-top-color: #fff;
    animation: spin .7s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }

.otp-resend { text-align: center; font-size: .83rem; color: #64748b; margin-bottom: 8px; }
.otp-resend-link { color: #0d9488; font-weight: 700; cursor: pointer; text-decoration: none; }
.otp-resend-link.disabled { color: #94a3b8; cursor: not-allowed; pointer-events: none; }

.auth-footer-note {
    text-align: center; font-size: .78rem; color: #94a3b8;
    margin-top: 22px; line-height: 1.6;
}
.auth-footer-note a { color: #0d9488; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.auth-footer-note a:hover { color: #0f766e; }

/* Responsive */
@@media (max-width: 900px) {
    .auth-page { padding: 0; }
    .auth-card { border-radius: 0; box-shadow: none; min-height: 100vh; }
    .auth-left { display: none; }
    .auth-right { width: 100%; padding: 40px 24px; }
}
@@media (max-width: 500px) {
    .otp-box  { width: 42px; height: 50px; font-size: 1.15rem; }
    .otp-inputs { gap: 6px; }
}
</style>
}

<div class="auth-page">
<div class="auth-card">

    <!-- ── Left panel ── -->
    <div class="auth-left">
        <div class="auth-left-blob b1"></div>
        <div class="auth-left-blob b2"></div>

        <div class="auth-brand">
            <div class="auth-brand-icon" id="heroLogoWrap"><i class="ri-hospital-line"></i></div>
            <div>
                <div class="auth-brand-name" id="heroBrandName">ClinicMS</div>
                <div class="auth-brand-sub">Clinic Management System</div>
            </div>
        </div>

        <div class="auth-hero">
            <h2>Care Better.<br>Run <span class="accent">Smarter.</span></h2>
            <p>A complete clinic management platform for patients, staff, billing, and inventory — <strong>all in one place.</strong></p>
        </div>

        <div class="auth-features">
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-group-line"></i></div>
                <div>
                    <div class="auth-feature-title">Patient Management</div>
                    <div class="auth-feature-desc">Complete patient records and treatment history</div>
                </div>
            </div>
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-calendar-check-line"></i></div>
                <div>
                    <div class="auth-feature-title">Smart Appointments</div>
                    <div class="auth-feature-desc">Schedule and manage appointments effortlessly</div>
                </div>
            </div>
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-bill-line"></i></div>
                <div>
                    <div class="auth-feature-title">Billing &amp; Invoicing</div>
                    <div class="auth-feature-desc">Generate invoices and manage payments seamlessly</div>
                </div>
            </div>
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-box-3-line"></i></div>
                <div>
                    <div class="auth-feature-title">Inventory Control</div>
                    <div class="auth-feature-desc">Track and manage inventory in real time</div>
                </div>
            </div>
        </div>

        <div class="auth-quote">
            <div class="auth-quote-icon"><i class="ri-double-quotes-l"></i></div>
            <div class="auth-quote-text">Empowering clinics to deliver exceptional care and achieve operational excellence.</div>
        </div>
    </div>

    <!-- ── Right panel ── -->
    <div class="auth-right">
        <div class="auth-form-wrap">

            <!-- OTP main content -->
            <div id="otpMain">
                <div class="auth-form-logo" id="formLogoWrap">
                    <i class="ri-message-2-line"></i>
                </div>

                <div class="auth-form-title">Verify Your Identity</div>
                <div class="auth-form-sub">We sent a 6-digit code to</div>
                <div class="auth-form-sub"><span class="otp-email" id="otpEmailDisplay">loading…</span></div>

                <div class="otp-sent-info">
                    <i class="ri-shield-check-line"></i>
                    Code expires in <span class="otp-timer" id="timerDisplay">05:00</span>
                </div>

                <!-- 6 digit boxes -->
                <div class="otp-inputs" id="otpInputs">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                    <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                </div>

                <button class="auth-btn" id="verifyBtn" onclick="verifyOtp()" disabled>
                    <span class="btn-text">Verify &amp; Sign In <i class="ri-arrow-right-line"></i></span>
                </button>

                <div class="otp-resend">
                    Didn't receive the code?
                    <a class="otp-resend-link disabled" id="resendLink" onclick="resendOtp()">
                        Resend (<span id="resendTimer">60</span>s)
                    </a>
                </div>
            </div>

            <div class="auth-footer-note">
                <a href="/Account/Login"><i class="ri-arrow-left-line"></i> Back to Sign In</a>
            </div>

        </div>
    </div>

</div>
</div>

@section scripts {
<script>
    var CLINIC_BRANDING = @Html.Raw(ViewBag.BrandingJson ?? "null");
</script>
<script src="~/scripts/Features/branding.js" asp-append-version="true"></script>
<script src="~/scripts/Features/otp.js" asp-append-version="true"></script>
}
