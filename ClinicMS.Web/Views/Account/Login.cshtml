@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section styles {
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

.auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background:
        radial-gradient(circle, #ccfbf1 1px, transparent 1px) 0 0/22px 22px,
        #f0fdfa;
}

.auth-card {
    width: 100%;
    max-width: 1120px;
    min-height: 660px;
    display: flex;
    border-radius: 28px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 30px 80px rgba(15,118,110,.18), 0 8px 24px rgba(15,23,42,.08);
}

/* ── Left panel ── */
.auth-left {
    width: 54%;
    background: linear-gradient(155deg, #0b4a44 0%, #0d9488 45%, #0891b2 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 56px;
    position: relative;
    overflow: hidden;
}
.auth-left::before {
    content: "";
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.auth-left-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: .2;
    pointer-events: none;
}
.auth-left-blob.b1 { width: 320px; height: 320px; background: #ccfbf1; top: -100px; right: -100px; }
.auth-left-blob.b2 { width: 240px; height: 240px; background: #bae6fd; bottom: -80px; left: -60px; }

.auth-brand {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 44px; position: relative; z-index: 1;
}
.auth-brand-icon {
    width: 48px; height: 48px; border-radius: 14px;
    background: rgba(255,255,255,.16); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem; color: #fff; border: 1.5px solid rgba(255,255,255,.28);
    overflow: hidden;
}
.auth-brand-name { font-size: 1.35rem; font-weight: 800; color: #fff; letter-spacing: -.02em; }
.auth-brand-sub  { font-size: .72rem; color: rgba(255,255,255,.62); font-weight: 500; margin-top: 1px; }

.auth-hero { position: relative; z-index: 1; margin-bottom: 40px; }
.auth-hero h2 {
    font-size: 2.15rem; font-weight: 800; color: #fff;
    line-height: 1.18; letter-spacing: -.02em; margin-bottom: 14px;
}
.auth-hero h2 .accent { color: #99f6e4; }
.auth-hero p { font-size: .92rem; color: rgba(255,255,255,.72); line-height: 1.65; max-width: 420px; }
.auth-hero p strong { color: rgba(255,255,255,.92); font-weight: 700; }

.auth-features {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 18px;
    margin-bottom: 32px;
}
.auth-feature { display: flex; align-items: flex-start; gap: 14px; }
.auth-feature-icon {
    width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.15rem;
}
.auth-feature-title { font-size: .88rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
.auth-feature-desc { font-size: .78rem; color: rgba(255,255,255,.62); line-height: 1.5; }

.auth-quote {
    position: relative; z-index: 1;
    display: flex; align-items: flex-start; gap: 12px;
    padding-top: 24px; border-top: 1px solid rgba(255,255,255,.16);
}
.auth-quote-icon {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background: rgba(255,255,255,.16);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: .85rem;
}
.auth-quote-text { font-size: .82rem; color: rgba(255,255,255,.75); line-height: 1.6; font-style: italic; }

/* ── Right panel ── */
.auth-right {
    width: 46%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 56px 48px;
}
.auth-form-wrap { width: 100%; max-width: 380px; }

.auth-form-logo {
    width: 60px; height: 60px; border-radius: 16px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.6rem;
    margin: 0 auto 20px; overflow: hidden;
    box-shadow: 0 10px 24px rgba(13,148,136,.3);
}

.auth-form-title {
    font-size: 1.5rem; font-weight: 800; color: #0f172a;
    letter-spacing: -.02em; margin-bottom: 6px; text-align: center;
}
.auth-form-sub { font-size: .85rem; color: #64748b; margin-bottom: 30px; text-align: center; line-height: 1.5; }

.auth-field { margin-bottom: 18px; }
.auth-label {
    display: block; font-size: .78rem; font-weight: 700;
    color: #374151; margin-bottom: 7px; letter-spacing: .02em;
}
.auth-input-wrap { position: relative; }
.auth-input-wrap i.prefix {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; font-size: 1rem; pointer-events: none;
}
.auth-input {
    width: 100%; height: 48px;
    padding: 0 14px 0 42px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: .9rem; color: #1e293b;
    background: #f8fafc;
    outline: none;
    transition: border-color .15s, box-shadow .15s, background .15s;
    font-family: 'Poppins', sans-serif;
}
.auth-input:focus {
    border-color: #0d9488;
    box-shadow: 0 0 0 3px rgba(13,148,136,.12);
    background: #fff;
}
.auth-toggle-pw {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; cursor: pointer; font-size: 1rem;
    background: none; border: none; padding: 0;
    transition: color .15s;
}
.auth-toggle-pw:hover { color: #0d9488; }

.auth-options {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
}
.auth-remember { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: #475569; cursor: pointer; }
.auth-remember input { width: 16px; height: 16px; accent-color: #0d9488; cursor: pointer; }
.auth-forgot { font-size: .82rem; color: #0d9488; font-weight: 600; text-decoration: none; }
.auth-forgot:hover { color: #0f766e; }

.auth-btn {
    width: 100%; height: 50px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    border: none; border-radius: 12px;
    font-size: .95rem; font-weight: 700; color: #fff;
    cursor: pointer; letter-spacing: .02em;
    transition: opacity .15s, transform .12s, box-shadow .15s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Poppins', sans-serif;
    box-shadow: 0 4px 16px rgba(13,148,136,.35);
}
.auth-btn:hover  { opacity: .92; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(13,148,136,.4); }
.auth-btn:active { transform: translateY(0); }
.auth-btn.loading .btn-text { display: none; }
.auth-btn.loading::after {
    content: "";
    width: 20px; height: 20px; border-radius: 50%;
    border: 2.5px solid rgba(255,255,255,.4);
    border-top-color: #fff;
    animation: spin .7s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }

.auth-divider {
    text-align: center; font-size: .78rem; color: #94a3b8;
    margin: 24px 0; position: relative;
}
.auth-divider::before {
    content: ""; position: absolute;
    top: 50%; left: 0; right: 0; height: 1px; background: #f1f5f9;
}
.auth-divider span { background: #fff; padding: 0 14px; position: relative; }

.auth-google-btn {
    width: 100%; height: 48px;
    background: #fff; border: 1.5px solid #e2e8f0; border-radius: 12px;
    font-size: .87rem; font-weight: 600; color: #334155;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
    font-family: 'Poppins', sans-serif;
    transition: background .15s, border-color .15s;
}
.auth-google-btn:hover { background: #f8fafc; border-color: #cbd5e1; }

.auth-footer-note {
    text-align: center; font-size: .78rem; color: #94a3b8;
    margin-top: 30px; line-height: 1.6;
}
.auth-footer-note .ver { font-size: .72rem; color: #cbd5e1; }

/* Error state */
.auth-input.is-error { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.1); }
.auth-err { font-size: .76rem; color: #ef4444; margin-top: 5px; display: none; }
.auth-err.show { display: block; }

/* Responsive */
@@media (max-width: 900px) {
    .auth-page { padding: 0; }
    .auth-card { border-radius: 0; box-shadow: none; min-height: 100vh; }
    .auth-left { display: none; }
    .auth-right { width: 100%; padding: 40px 24px; }
}
</style>
}

<div class="auth-page">
<div class="auth-card">

    <!-- ── Left panel ── -->
    <div class="auth-left">
        <div class="auth-left-blob b1"></div>
        <div class="auth-left-blob b2"></div>

        <div class="auth-brand">
            <div class="auth-brand-icon" id="heroLogoWrap"><i class="ri-hospital-line"></i></div>
            <div>
                <div class="auth-brand-name" id="heroBrandName">ClinicMS</div>
                <div class="auth-brand-sub">Clinic Management System</div>
            </div>
        </div>

        <div class="auth-hero">
            <h2>Care Better.<br>Run <span class="accent">Smarter.</span></h2>
            <p>A complete clinic management platform for patients, staff, billing, and inventory — <strong>all in one place.</strong></p>
        </div>

        <div class="auth-features">
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-group-line"></i></div>
                <div>
                    <div class="auth-feature-title">Patient Management</div>
                    <div class="auth-feature-desc">Complete patient records and treatment history</div>
                </div>
            </div>
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-bill-line"></i></div>
                <div>
                    <div class="auth-feature-title">Billing &amp; Invoicing</div>
                    <div class="auth-feature-desc">Generate invoices and manage payments seamlessly</div>
                </div>
            </div>
            <div class="auth-feature">
                <div class="auth-feature-icon"><i class="ri-box-3-line"></i></div>
                <div>
                    <div class="auth-feature-title">Inventory Control</div>
                    <div class="auth-feature-desc">Track and manage inventory in real time</div>
                </div>
            </div>
        </div>

        <div class="auth-quote">
            <div class="auth-quote-icon"><i class="ri-double-quotes-l"></i></div>
            <div class="auth-quote-text">Empowering clinics to deliver exceptional care and achieve operational excellence.</div>
        </div>
    </div>

    <!-- ── Right panel ── -->
    <div class="auth-right">
        <div class="auth-form-wrap">

            <div class="auth-form-logo" id="formLogoWrap">
                <i class="ri-hospital-line"></i>
            </div>

            <div class="auth-form-title">Welcome Back</div>
            <div class="auth-form-sub">Sign in to your account to continue</div>

            <div class="auth-field">
                <label class="auth-label">Email Address</label>
                <div class="auth-input-wrap">
                    <i class="ri-mail-line prefix"></i>
                    <input type="text" class="auth-input" id="loginUser" placeholder="youremail@clinicms.com" autocomplete="username">
                </div>
                <div class="auth-err" id="errUser">Please enter your username or email</div>
            </div>

            <div class="auth-field">
                <label class="auth-label">Password</label>
                <div class="auth-input-wrap">
                    <i class="ri-lock-2-line prefix"></i>
                    <input type="password" class="auth-input" id="loginPass" placeholder="••••••••" autocomplete="current-password">
                    <button class="auth-toggle-pw" type="button" onclick="togglePassword()" id="pwToggleBtn">
                        <i class="ri-eye-off-line" id="pwToggleIcon"></i>
                    </button>
                </div>
                <div class="auth-err" id="errPass">Please enter your password</div>
            </div>

            <div class="auth-options">
                <label class="auth-remember">
                    <input type="checkbox" id="rememberMe" checked>
                    Remember me
                </label>
                <a href="#" class="auth-forgot">Forgot Password?</a>
            </div>

            <!-- General error -->
            <div id="errGeneral" style="display:none;align-items:center;gap:10px;background:#fef2f2;border:1.5px solid #fecaca;border-radius:10px;padding:11px 14px;margin-bottom:18px;font-size:.82rem;color:#b91c1c;font-weight:600;">
                <i class="ri-error-warning-line" style="font-size:1rem;flex-shrink:0;"></i>
                Invalid username or password. Please try again.
            </div>

            <button class="auth-btn" id="loginBtn" onclick="doLogin()">
                <span class="btn-text">Sign In <i class="ri-arrow-right-line"></i></span>
            </button>

            <div class="auth-divider"><span>or</span></div>

            <button type="button" class="auth-google-btn" id="googleSignInBtn">
                <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.9c1.7-1.57 2.7-3.87 2.7-6.62z"/>
                    <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.9-2.26c-.8.54-1.83.86-3.06.86-2.35 0-4.34-1.59-5.05-3.72H.96v2.33A9 9 0 0 0 9 18z"/>
                    <path fill="#FBBC05" d="M3.95 10.7A5.4 5.4 0 0 1 3.67 9c0-.59.1-1.17.28-1.7V4.97H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.03l2.99-2.33z"/>
                    <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.46.9 11.43 0 9 0A9 9 0 0 0 .96 4.97l2.99 2.33C4.66 5.17 6.65 3.58 9 3.58z"/>
                </svg>
                Sign in with Google
            </button>

            <div class="auth-footer-note">
                <span id="footerBrandName">ClinicMS</span> &copy; @DateTime.Now.Year. All rights reserved.<br>
                <span class="ver">Version 1.0.0</span>
            </div>

        </div>
    </div>

</div>
</div>

@section scripts {
<script>
    var CLINIC_BRANDING = @Html.Raw(ViewBag.BrandingJson ?? "null");
</script>
<script src="~/scripts/Features/branding.js" asp-append-version="true"></script>
<script src="~/scripts/Features/login.js" asp-append-version="true"></script>
<script>
    document.getElementById('googleSignInBtn').addEventListener('click', function () {
        if (typeof toastr !== 'undefined') {
            toastr.info('Google sign-in is not configured yet.');
        }
    });
</script>
}
