@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section styles {
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

.auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    background:
        radial-gradient(circle, #ccfbf1 1px, transparent 1px) 0 0/22px 22px,
        #f0fdfa;
}

.auth-card-narrow {
    width: 100%;
    max-width: 420px;
    border-radius: 28px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 30px 80px rgba(15,118,110,.18), 0 8px 24px rgba(15,23,42,.08);
    padding: 48px 40px;
}

.auth-form-logo {
    width: 60px; height: 60px; border-radius: 16px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.6rem;
    margin: 0 auto 20px; overflow: hidden;
    box-shadow: 0 10px 24px rgba(13,148,136,.3);
}

.auth-form-title {
    font-size: 1.5rem; font-weight: 800; color: #0f172a;
    letter-spacing: -.02em; margin-bottom: 6px; text-align: center;
}
.auth-form-sub { font-size: .85rem; color: #64748b; margin-bottom: 26px; text-align: center; line-height: 1.5; }

.auth-field { margin-bottom: 18px; }
.auth-label {
    display: block; font-size: .78rem; font-weight: 700;
    color: #374151; margin-bottom: 7px; letter-spacing: .02em;
}
.auth-input-wrap { position: relative; }
.auth-input-wrap i.prefix {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; font-size: 1rem; pointer-events: none;
}
.auth-input {
    width: 100%; height: 48px;
    padding: 0 14px 0 42px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: .9rem; color: #1e293b;
    background: #f8fafc;
    outline: none;
    transition: border-color .15s, box-shadow .15s, background .15s;
    font-family: 'Poppins', sans-serif;
}
.auth-input:focus {
    border-color: #0d9488;
    box-shadow: 0 0 0 3px rgba(13,148,136,.12);
    background: #fff;
}
.auth-toggle-pw {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; cursor: pointer; font-size: 1rem;
    background: none; border: none; padding: 0;
    transition: color .15s;
}
.auth-toggle-pw:hover { color: #0d9488; }

.auth-btn {
    width: 100%; height: 50px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    border: none; border-radius: 12px;
    font-size: .95rem; font-weight: 700; color: #fff;
    cursor: pointer; letter-spacing: .02em;
    transition: opacity .15s, transform .12s, box-shadow .15s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Poppins', sans-serif;
    box-shadow: 0 4px 16px rgba(13,148,136,.35);
    margin-bottom: 14px;
}
.auth-btn:hover  { opacity: .92; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(13,148,136,.4); }
.auth-btn:active { transform: translateY(0); }
.auth-btn.loading .btn-text { display: none; }
.auth-btn.loading::after {
    content: "";
    width: 20px; height: 20px; border-radius: 50%;
    border: 2.5px solid rgba(255,255,255,.4);
    border-top-color: #fff;
    animation: spin .7s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }

.auth-resend { text-align: center; font-size: .83rem; color: #64748b; margin-bottom: 14px; }
.auth-resend-link { color: #0d9488; font-weight: 700; cursor: pointer; text-decoration: none; }

.auth-footer-note {
    text-align: center; font-size: .78rem; color: #94a3b8;
    margin-top: 6px; line-height: 1.6;
}
.auth-footer-note a { color: #0d9488; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.auth-footer-note a:hover { color: #0f766e; }
</style>
}

<div class="auth-page">
<div class="auth-card-narrow">

    <div class="auth-form-logo"><i class="ri-lock-password-line"></i></div>

    <div class="auth-form-title">Reset Your Password</div>
    <div class="auth-form-sub">Enter the code we emailed you and choose a new password</div>

    <div class="auth-field">
        <label class="auth-label">Reset Code</label>
        <div class="auth-input-wrap">
            <i class="ri-shield-keyhole-line prefix"></i>
            <input type="text" inputmode="numeric" maxlength="6" class="auth-input" id="fCode" placeholder="6-digit code">
        </div>
    </div>

    <div class="auth-field">
        <label class="auth-label">New Password</label>
        <div class="auth-input-wrap">
            <i class="ri-lock-2-line prefix"></i>
            <input type="password" class="auth-input" id="fNewPassword" placeholder="At least 6 characters" autocomplete="new-password">
            <button class="auth-toggle-pw" type="button" onclick="togglePw('fNewPassword', this)"><i class="ri-eye-off-line"></i></button>
        </div>
    </div>

    <div class="auth-field">
        <label class="auth-label">Confirm New Password</label>
        <div class="auth-input-wrap">
            <i class="ri-lock-2-line prefix"></i>
            <input type="password" class="auth-input" id="fConfirmPassword" placeholder="Re-enter password" autocomplete="new-password">
            <button class="auth-toggle-pw" type="button" onclick="togglePw('fConfirmPassword', this)"><i class="ri-eye-off-line"></i></button>
        </div>
    </div>

    <button class="auth-btn" id="submitBtn" onclick="submitResetPassword()">
        <span class="btn-text">Reset Password <i class="ri-arrow-right-line"></i></span>
    </button>

    <div class="auth-resend">
        Didn't get a code? <a class="auth-resend-link" onclick="resendResetCode()">Resend</a>
    </div>

    <div class="auth-footer-note">
        <a href="/Account/Login"><i class="ri-arrow-left-line"></i> Back to Sign In</a>
    </div>

</div>
</div>

@section scripts {
<script>
    var CLINIC_BRANDING = @Html.Raw(ViewBag.BrandingJson ?? "null");
</script>
<script src="~/scripts/Features/branding.js" asp-append-version="true"></script>
<script src="~/scripts/Features/forgot-password.js" asp-append-version="true"></script>
}
