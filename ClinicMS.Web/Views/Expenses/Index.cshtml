@{
    ViewData["Title"] = "Expense Entry";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Expense Entry";
}

@section styles {
<style>
    
.gp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.gp-title { font-size:1.25rem; font-weight:800; color:#1e293b; margin:0; }
.gp-sub { font-size:.82rem; color:#64748b; margin:3px 0 0; }
.gp-card { background:#fff; border-radius:16px; border:1px solid #e2e8f0; box-shadow:0 2px 12px rgba(15,23,42,.06); padding:20px; }
.gp-stat-card { background:#fff; border-radius:14px; border:1px solid #e2e8f0; padding:18px 20px; }
.gp-stat-val { font-size:1.6rem; font-weight:900; line-height:1; }
.gp-stat-lbl { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#94a3b8; margin-top:4px; }
.gp-filters { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; align-items:center; }
.gp-search { position:relative; flex:1; min-width:220px; }
.gp-search input { width:100%; height:38px; padding:0 12px 0 38px; border-radius:10px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:.875rem; outline:none; }
.gp-search input:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }
.gp-search i { position:absolute; left:11px; top:50%; transform:translateY(-50%); color:#94a3b8; }
.gp-select { height:38px; padding:0 10px; border-radius:10px; border:1.5px solid #e2e8f0; background:#f8fafc; font-size:.875rem; outline:none; color:#475569; }
.gp-table { width:100%; border-collapse:collapse; }
.gp-table thead th { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; background:#f8fafc; border-bottom:2px solid #f1f5f9; padding:10px 14px; white-space:nowrap; }
.gp-table tbody td { padding:12px 14px; border-bottom:1px solid #f8fafc; font-size:.875rem; color:#334155; vertical-align:middle; }
.gp-table tbody tr:hover td { background:#f8fafc; }
.gp-table tbody tr:last-child td { border-bottom:none; }
.gp-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:999px; font-size:.7rem; font-weight:700; }
.gp-badge-green { background:#dcfce7; color:#15803d; }
.gp-badge-blue { background:#dbeafe; color:#1d4ed8; }
.gp-badge-teal { background:#ccfbf1; color:#0f766e; }
.gp-badge-purple { background:#ede9fe; color:#6d28d9; }
.gp-badge-orange { background:#ffedd5; color:#c2410c; }
.gp-badge-amber { background:#fef3c7; color:#b45309; }
.gp-btn-icon { width:32px; height:32px; border-radius:8px; border:none; display:inline-flex; align-items:center; justify-content:center; font-size:.9rem; cursor:pointer; transition:all .15s; }
.gp-btn-edit { background:#f0fdfa; color:#0d9488; }
.gp-btn-edit:hover { background:#0d9488; color:#fff; }
.gp-btn-delete { background:#fef2f2; color:#dc2626; }
.gp-btn-delete:hover { background:#dc2626; color:#fff; }
.gp-btn-view { background:#eff6ff; color:#2563eb; }
.gp-btn-view:hover { background:#2563eb; color:#fff; }
.gp-pagination { display:flex; align-items:center; justify-content:space-between; margin-top:16px; flex-wrap:wrap; gap:10px; }
.gp-page-info { font-size:.78rem; color:#64748b; }
.gp-page-btns { display:flex; gap:4px; }
.gp-page-btn { width:32px; height:32px; border-radius:8px; border:1.5px solid #e2e8f0; background:#fff; color:#475569; font-size:.78rem; font-weight:600; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; }
.gp-page-btn.active, .gp-page-btn:hover { border-color:#0d9488; background:#0d9488; color:#fff; }
.modal-content { border-radius:20px; border:none; }
.modal-header { background:#f8fafc; border-radius:20px 20px 0 0; border-bottom:1px solid #f1f5f9; padding:18px 24px; }
.modal-title { font-weight:800; color:#1e293b; font-size:1rem; }
.modal-body { padding:24px; }
.modal-footer { border-top:1px solid #f1f5f9; padding:16px 24px; }
.form-label { font-size:.8rem; font-weight:700; color:#475569; margin-bottom:5px; }
.form-control, .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.875rem; padding:8px 12px; }
.form-control:focus, .form-select:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }
</style>
}

<div class="gp-page">
    <div class="gp-header">
        <div>
            <h4 class="gp-title">Expense Entry</h4>
            <p class="gp-sub">Record and review individual expense transactions</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Expenses/Setup" class="btn btn-sm px-3 py-2 fw-700" style="border:1.5px solid #e2e8f0;color:#475569;border-radius:10px;">
                <i class="ri-settings-3-line me-1"></i> Expense Setup
            </a>
            <button id="btnGenerateRecurring" class="btn btn-sm px-3 py-2 fw-700" style="border:1.5px solid #e2e8f0;color:#475569;border-radius:10px;" onclick="generateRecurring()" title="Check Setup Expenses schedules for anything due (by frequency and date) and generate entries">
                <i class="ri-refresh-line me-1"></i> Generate Setup Expenses
            </button>
            <button class="btn btn-sm px-3 py-2 fw-700 text-white" style="background:#0d9488;border-radius:10px;" onclick="openModal()">
                <i class="ri-add-line me-1"></i> Add Expense
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="gp-stat-card">
                <div class="gp-stat-val" style="color:#dc2626;" id="statMonthly">0</div>
                <div class="gp-stat-lbl">Monthly Total (EGP)</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="gp-stat-card">
                <div class="gp-stat-val" style="color:#d97706;" id="statToday">0</div>
                <div class="gp-stat-lbl">Today's Expenses</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="gp-stat-card">
                <div class="gp-stat-val" style="color:#475569;" id="statCount">0</div>
                <div class="gp-stat-lbl">Total Records</div>
            </div>
        </div>
    </div>

    <div class="gp-card mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <h6 class="mb-0" style="font-weight:800;color:#1e293b;">Monthly Budget by Account</h6>
                <p class="mb-0" style="font-size:.78rem;color:#94a3b8;">How much of each account's estimate is left this month</p>
            </div>
        </div>
        <div class="row g-3" id="budgetSummaryRow"></div>
    </div>

    <div class="gp-card">
        <div class="gp-filters">
            <div class="gp-search">
                <i class="ri-search-line"></i>
                <input type="text" id="searchInput" placeholder="Search expenses..." oninput="handleSearch(this.value)">
            </div>
            <select class="gp-select" id="catFilter" onchange="handleFilter()">
                <option value="">All Categories</option>
            </select>
            <select class="gp-select" id="methodFilter" onchange="handleFilter()">
                <option value="">All Methods</option>
                <option value="Cash">Cash</option>
                <option value="CreditCard">Credit Card</option>
                <option value="BankTransfer">Bank Transfer</option>
                <option value="WalletCredit">Wallet Credit</option>
                <option value="Unassigned">Needs Review (auto-generated)</option>
            </select>
        </div>
        <div style="overflow-x:auto;">
            <table class="gp-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Title</th>
                        <th>Date</th>
                        <th>Vendor</th>
                        <th>Method</th>
                        <th>Account</th>
                        <th>Receipt #</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="expensesTableBody"></tbody>
            </table>
        </div>
        <div class="gp-pagination">
            <span class="gp-page-info" id="pageInfo"></span>
            <div class="gp-page-btns" id="pageBtns"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="expenseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Expense</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label required">Category</label>
                        <select class="form-select" id="fCategory"></select>
                    </div>
                    <div class="col-6">
                        <label class="form-label required">Amount</label>
                        <input type="number" class="form-control" id="fAmount">
                    </div>
                    <div class="col-12">
                        <label class="form-label required">Title</label>
                        <input type="text" class="form-control" id="fTitle" placeholder="e.g. Monthly electricity bill">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" id="fDate">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Receipt #</label>
                        <input type="text" class="form-control" id="fReceipt" placeholder="Optional">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Vendor</label>
                        <select class="form-select" id="fVendor">
                            <option value="">— None —</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Method</label>
                        <select class="form-select" id="fMethod">
                            <option value="Cash">Cash</option>
                            <option value="CreditCard">Credit Card</option>
                            <option value="BankTransfer">Bank Transfer</option>
                            <option value="WalletCredit">Wallet Credit</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Paid From Account</label>
                        <select class="form-select" id="fAccount">
                            <option value="">— None —</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white px-4" style="background:#0d9488;border-radius:10px;" onclick="saveExpense()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var EXPENSES_PAGE_DATA = @Html.Raw(ViewBag.ExpensesPageJson);
    var EXP_CATEGORIES  = @Html.Raw(ViewBag.CategoriesJson);
    var EXP_VENDORS     = @Html.Raw(ViewBag.VendorsJson);
    var EXP_ACCOUNTS    = @Html.Raw(ViewBag.PaymentAccountsJson);
    var EXP_BUDGET_SUMMARY = @Html.Raw(ViewBag.BudgetSummaryJson ?? "[]");
</script>
<script src="~/scripts/Features/expenses.js"></script>
}
