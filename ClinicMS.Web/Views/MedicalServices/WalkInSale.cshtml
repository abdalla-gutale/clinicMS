@{
    ViewData["Title"] = "Walk-in Sale";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "Walk-in Sale";
}

@section styles {
<style>

.gp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.gp-title { font-size:1.25rem; font-weight:800; color:#1e293b; margin:0; }
.gp-sub { font-size:.82rem; color:#64748b; margin:3px 0 0; }
.gp-card { background:#fff; border-radius:16px; border:1px solid #e2e8f0; box-shadow:0 2px 12px rgba(15,23,42,.06); padding:20px; margin-bottom:20px; }
.gp-card-title { font-size:1rem; font-weight:800; color:#1e293b; margin:0 0 14px; }
.form-label { font-size:.8rem; font-weight:700; color:#475569; margin-bottom:5px; }
.form-control, .form-select { border-radius:10px; border:1.5px solid #e2e8f0; font-size:.875rem; padding:8px 12px; }
.form-control:focus, .form-select:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,.1); }

.wi-items-table { width:100%; border-collapse:collapse; margin-top:14px; }
.wi-items-table thead th { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.06em; color:#94a3b8; background:#f8fafc; border-bottom:2px solid #f1f5f9; padding:10px 12px; text-align:left; }
.wi-items-table tbody td { padding:9px 12px; border-bottom:1px solid #f8fafc; font-size:.85rem; color:#334155; }
.wi-items-empty { padding:20px; text-align:center; color:#94a3b8; font-size:.82rem; }
.wi-type-badge { display:inline-flex; align-items:center; padding:2px 9px; border-radius:999px; font-size:.68rem; font-weight:700; }
.wi-type-service { background:#ede9fe; color:#6d28d9; }
.wi-type-product { background:#ccfbf1; color:#0f766e; }

.wi-totals { max-width:340px; margin-left:auto; margin-top:14px; }
.wi-totals-row { display:flex; justify-content:space-between; font-size:.85rem; color:#475569; padding:5px 0; }
.wi-totals-row.total { font-weight:800; font-size:1.05rem; color:#0d9488; border-top:2px solid #0d9488; padding-top:8px; margin-top:4px; }

.wi-receipt { display:none; padding:16px 18px; border-radius:14px; background:#f0fdfa; border:1.5px solid #ccfbf1; color:#134e4a; margin-bottom:20px; }
.wi-receipt b { color:#0f766e; }
</style>
}

<div class="gp-page">
    <div class="gp-header">
        <div>
            <h4 class="gp-title">Walk-in Sale</h4>
            <p class="gp-sub">Charge a registered patient for services or products directly — no treatment plan or cycle required</p>
        </div>
    </div>

    <div class="wi-receipt" id="wiReceipt"></div>

    <div class="gp-card">
        <h5 class="gp-card-title">Patient</h5>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">Patient</label>
                <select class="form-select" id="wPatient">
                    <option value="">Select a patient…</option>
                </select>
            </div>
        </div>
    </div>

    <div class="gp-card">
        <h5 class="gp-card-title">Services &amp; Products</h5>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">Services</label>
                <select class="form-select" id="wServices" multiple></select>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Products</label>
                <select class="form-select" id="wProducts" multiple></select>
            </div>
        </div>

        <table class="wi-items-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Type</th>
                    <th style="text-align:right;">Price</th>
                </tr>
            </thead>
            <tbody id="wiItemsBody"></tbody>
        </table>
        <div class="wi-items-empty" id="wiItemsEmpty">No services or products selected yet.</div>

        <div class="wi-totals">
            <div class="wi-totals-row"><span>Subtotal</span><b id="wiSubtotal">0.00</b></div>
            <div class="wi-totals-row">
                <span>Discount</span>
                <input type="text" inputmode="decimal" class="form-control" id="wDiscount" style="width:120px;text-align:right;" placeholder="0.00" oninput="onWalkInInputsChange()">
            </div>
            <div class="wi-totals-row"><span>VAT (<span id="wiVatPct">0</span>%)</span><b id="wiVat">0.00</b></div>
            <div class="wi-totals-row total"><span>Net Total</span><b id="wiNetTotal">0.00</b></div>
        </div>
    </div>

    <div class="gp-card">
        <h5 class="gp-card-title">Payment</h5>
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Payment Method</label>
                <select class="form-select" id="wMethod">
                    <option value="Cash">Cash</option>
                    <option value="CreditCard">Credit Card</option>
                    <option value="BankTransfer">Bank Transfer</option>
                    <option value="WalletCredit">Wallet Credit</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Account</label>
                <select class="form-select" id="wAccount">
                    <option value="">— None —</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Reference (optional)</label>
                <input type="text" class="form-control" id="wReference" placeholder="e.g. receipt #">
            </div>
        </div>
        <div class="d-flex justify-content-end mt-3">
            <button type="button" class="btn text-white px-4" style="background:#0d9488;border-radius:10px;font-weight:700;" onclick="submitWalkInSale()">
                <i class="ri-check-line me-1"></i> Complete Sale
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var WALKIN_PATIENTS_DATA = @Html.Raw(ViewBag.WalkInPatientsJson);
    var WALKIN_SERVICES_DATA = @Html.Raw(ViewBag.WalkInServicesJson);
    var WALKIN_PRODUCTS_DATA = @Html.Raw(ViewBag.WalkInProductsJson);
    var WALKIN_ACCOUNTS_DATA = @Html.Raw(ViewBag.WalkInPaymentAccountsJson);
    var WALKIN_VAT_PERCENTAGE = @Html.Raw(ViewBag.VatPercentage);
    var WALKIN_CURRENCY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)ViewBag.CurrencySymbol));
</script>
<script src="~/scripts/Features/walk-in-sale.js"></script>
}
