@{
    ViewData["Title"] = "General Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.pTitle = "General Settings";
}

@section styles {
<style>
.settings-wrap { padding: 24px; }

/* ── Left Nav ── */
.settings-nav {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 12px rgba(15,23,42,.06);
    overflow: hidden;
    position: sticky;
    top: 80px;
}
.settings-nav-header {
    padding: 18px 20px 12px;
    font-size: .65rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #94a3b8;
    border-bottom: 1px solid #f1f5f9;
}
.settings-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 20px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all .16s;
    text-decoration: none;
    color: #475569;
    font-size: .875rem;
    font-weight: 600;
    border-bottom: 1px solid #f8fafc;
}
.settings-nav-item:last-child { border-bottom: none; }
.settings-nav-item:hover { background: #f0fdfa; color: #0d9488; border-left-color: #a7f3d0; }
.settings-nav-item.active { background: #f0fdfa; color: #0d9488; border-left-color: #0d9488; font-weight: 700; }
.settings-nav-item i { font-size: 1.05rem; width: 20px; text-align: center; flex-shrink: 0; }
.settings-nav-item .nav-desc { font-size: .72rem; color: #94a3b8; font-weight: 500; margin-top: 1px; }

/* ── Right Content ── */
.settings-panel { display: none; }
.settings-panel.active { display: block; }

.settings-card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 12px rgba(15,23,42,.06);
    overflow: hidden;
    margin-bottom: 20px;
}
.settings-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
    border-bottom: 1px solid #f1f5f9;
    background: #f8fafc;
}
.settings-card-header-icon {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: rgba(13,148,136,.1);
    color: #0d9488;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
}
.settings-card-title { font-size: .9rem; font-weight: 800; color: #1e293b; margin: 0; }
.settings-card-sub   { font-size: .76rem; color: #94a3b8; margin: 2px 0 0; }
.settings-card-body  { padding: 24px; }

.form-label { font-size: .8rem; font-weight: 700; color: #475569; margin-bottom: 5px; }
.form-control, .form-select {
    border-radius: 10px; border: 1.5px solid #e2e8f0;
    font-size: .875rem; padding: 9px 12px;
    transition: border-color .18s;
}
.form-control:focus, .form-select:focus {
    border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,.1);
}

/* Logo upload */
.logo-upload-area {
    width: 160px; height: 160px;
    border-radius: 20px;
    background: #f8fafc;
    border: 2px dashed #cbd5e1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    cursor: pointer; overflow: hidden;
    transition: border-color .18s, background .18s;
}
.logo-upload-area:hover { border-color: #0d9488; background: #f0fdfa; }
.logo-upload-area img { width:100%; height:100%; object-fit:contain; display:none; }
.logo-upload-area i  { font-size: 2.4rem; color: #94a3b8; }
.logo-upload-area small { font-size: .72rem; color: #94a3b8; margin-top: 6px; }

/* Logo slot (upload area + label + usage caption) */
.logo-slot { width: 180px; }
.logo-slot-label { font-size: .85rem; font-weight: 700; color: #1e293b; margin-top: 10px; }
.logo-slot-desc { font-size: .72rem; color: #94a3b8; line-height: 1.4; margin-top: 3px; }

/* VAT percentage suffix input */
.input-suffix-wrap { position: relative; }
.input-suffix-wrap .form-control { padding-right: 34px; }
.input-suffix-wrap .input-suffix {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    font-size: .8rem; font-weight: 700; color: #94a3b8; pointer-events: none;
}

/* Save bar */
.settings-save-bar {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 2px 8px rgba(15,23,42,.05);
}
.settings-save-hint { font-size: .82rem; color: #94a3b8; }

/* Discount Configuration table */
.settings-card-header { position: relative; }
.gp-table { width:100%; border-collapse:collapse; }
.gp-table thead th { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; background:#f8fafc; border-bottom:2px solid #f1f5f9; padding:10px 14px; white-space:nowrap; }
.gp-table tbody td { padding:12px 14px; border-bottom:1px solid #f8fafc; font-size:.875rem; color:#334155; vertical-align:middle; white-space:nowrap; }
.gp-table tbody tr:hover td { background:#f8fafc; }
.gp-table tbody tr:last-child td { border-bottom:none; }
.gp-btn-icon { width:32px; height:32px; border-radius:8px; border:none; display:inline-flex; align-items:center; justify-content:center; font-size:.9rem; cursor:pointer; transition:all .15s; }
.gp-btn-edit { background:#f0fdfa; color:#0d9488; }
.gp-btn-edit:hover { background:#0d9488; color:#fff; }
.gp-btn-delete { background:#fef2f2; color:#dc2626; }
.gp-btn-delete:hover { background:#dc2626; color:#fff; }
.gp-badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:.7rem; font-weight:700; }
.gp-badge-green { background:#dcfce7; color:#16a34a; }
.gp-badge-gray { background:#f1f5f9; color:#64748b; }
.gp-badge-yellow { background:#fef9c3; color:#a16207; }

/* DataTables theming to match the rest of Settings */
.dataTables_wrapper .dataTables_filter input {
    border-radius: 10px; border: 1.5px solid #e2e8f0; padding: 6px 12px; font-size: .82rem; outline: none;
}
.dataTables_wrapper .dataTables_filter input:focus { border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,.1); }
.dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_length label { font-size: .78rem; color: #64748b; }
.dataTables_wrapper .dataTables_paginate .paginate_button {
    border-radius: 8px !important; margin-left: 3px; font-size: .78rem !important;
    border: 1.5px solid #e2e8f0 !important; padding: 4px 10px !important;
}
.dataTables_wrapper .dataTables_paginate .paginate_button.current {
    background: #0d9488 !important; border-color: #0d9488 !important; color: #fff !important;
}
.dataTables_wrapper .dataTables_paginate .paginate_button:hover:not(.disabled) {
    background: #f0fdfa !important; border-color: #0d9488 !important; color: #0d9488 !important;
}
table.dataTable thead th { position: relative; }
</style>
}

<div class="settings-wrap">
    <div class="row g-4">

        <!-- ── LEFT NAV ── -->
        <div class="col-12 col-lg-3">
            <div class="settings-nav">
                <div class="settings-nav-header">Settings</div>

                <a class="settings-nav-item active" data-panel="gym" href="#">
                    <i class="ri-building-2-line"></i>
                    <div>
                        <div>Clinic Information</div>
                        <div class="nav-desc">Name, logo, contact details</div>
                    </div>
                </a>
                <a class="settings-nav-item" data-panel="accountsetup" href="#">
                    <i class="ri-bank-line"></i>
                    <div>
                        <div>Account Setup</div>
                        <div class="nav-desc">Merchant bank account details</div>
                    </div>
                </a>
                <a class="settings-nav-item" data-panel="discounts" href="#">
                    <i class="ri-price-tag-3-line"></i>
                    <div>
                        <div>Discount Configuration</div>
                        <div class="nav-desc">Promotions and discount rules</div>
                    </div>
                </a>
                <a class="settings-nav-item" data-panel="sms" href="#">
                    <i class="ri-message-2-line"></i>
                    <div>
                        <div>SMS Gateway</div>
                        <div class="nav-desc">Provider, API key, sender</div>
                    </div>
                </a>
                <a class="settings-nav-item" data-panel="smstemplates" href="#">
                    <i class="ri-file-list-3-line"></i>
                    <div>
                        <div>SMS Templates</div>
                        <div class="nav-desc">Message templates by type</div>
                    </div>
                </a>
            </div>
        </div>

        <!-- ── RIGHT CONTENT ── -->
        <div class="col-12 col-lg-9">

            <!-- PANEL: Gym Information -->
            <div class="settings-panel active" id="panel-gym">
                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-building-2-line"></i></div>
                        <div>
                            <div class="settings-card-title">Clinic Information</div>
                            <div class="settings-card-sub">Basic details about your gym</div>
                        </div>
                    </div>
                    <div class="settings-card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Clinic Name</label>
                                <input type="text" class="form-control" id="gymName">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Phone</label>
                                <input type="tel" inputmode="tel" autocomplete="off" class="form-control" id="gymPhone"
                                       onkeypress="return isPhoneKeyAllowed(event)" onpaste="return isPhonePasteAllowed(event)" oninput="sanitizePhone(this)">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" autocomplete="off" class="form-control" id="gymEmail" oninput="sanitizeEmail(this)">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Address</label>
                                <textarea class="form-control" id="gymAddress" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-percent-line"></i></div>
                        <div>
                            <div class="settings-card-title">Tax &amp; Currency</div>
                            <div class="settings-card-sub">VAT and currency applied to invoices</div>
                        </div>
                    </div>
                    <div class="settings-card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <label class="form-label">Currency</label>
                                <select class="form-select" id="currencySymbol">
                                    <option value="AED">AED — UAE Dirham (د.إ)</option>
                                    <option value="AFN">AFN — Afghan Afghani (؋)</option>
                                    <option value="ARS">ARS — Argentine Peso ($)</option>
                                    <option value="AUD">AUD — Australian Dollar (A$)</option>
                                    <option value="BDT">BDT — Bangladeshi Taka (৳)</option>
                                    <option value="BHD">BHD — Bahraini Dinar (.د.ب)</option>
                                    <option value="BRL">BRL — Brazilian Real (R$)</option>
                                    <option value="CAD">CAD — Canadian Dollar (C$)</option>
                                    <option value="CHF">CHF — Swiss Franc (CHF)</option>
                                    <option value="CNY">CNY — Chinese Yuan (¥)</option>
                                    <option value="CZK">CZK — Czech Koruna (Kč)</option>
                                    <option value="DKK">DKK — Danish Krone (kr)</option>
                                    <option value="DZD">DZD — Algerian Dinar (د.ج)</option>
                                    <option value="EGP">EGP — Egyptian Pound (ج.م)</option>
                                    <option value="ETB">ETB — Ethiopian Birr (Br)</option>
                                    <option value="EUR">EUR — Euro (€)</option>
                                    <option value="GBP">GBP — British Pound (£)</option>
                                    <option value="GHS">GHS — Ghanaian Cedi (₵)</option>
                                    <option value="HKD">HKD — Hong Kong Dollar (HK$)</option>
                                    <option value="HUF">HUF — Hungarian Forint (Ft)</option>
                                    <option value="IDR">IDR — Indonesian Rupiah (Rp)</option>
                                    <option value="ILS">ILS — Israeli Shekel (₪)</option>
                                    <option value="INR">INR — Indian Rupee (₹)</option>
                                    <option value="IQD">IQD — Iraqi Dinar (ع.د)</option>
                                    <option value="JOD">JOD — Jordanian Dinar (د.ا)</option>
                                    <option value="JPY">JPY — Japanese Yen (¥)</option>
                                    <option value="KES">KES — Kenyan Shilling (KSh)</option>
                                    <option value="KRW">KRW — South Korean Won (₩)</option>
                                    <option value="KWD">KWD — Kuwaiti Dinar (د.ك)</option>
                                    <option value="LBP">LBP — Lebanese Pound (ل.ل)</option>
                                    <option value="LKR">LKR — Sri Lankan Rupee (₨)</option>
                                    <option value="LYD">LYD — Libyan Dinar (ل.د)</option>
                                    <option value="MAD">MAD — Moroccan Dirham (د.م.)</option>
                                    <option value="MXN">MXN — Mexican Peso (Mex$)</option>
                                    <option value="MYR">MYR — Malaysian Ringgit (RM)</option>
                                    <option value="NGN">NGN — Nigerian Naira (₦)</option>
                                    <option value="NOK">NOK — Norwegian Krone (kr)</option>
                                    <option value="NPR">NPR — Nepalese Rupee (₨)</option>
                                    <option value="NZD">NZD — New Zealand Dollar (NZ$)</option>
                                    <option value="OMR">OMR — Omani Rial (ر.ع.)</option>
                                    <option value="PHP">PHP — Philippine Peso (₱)</option>
                                    <option value="PKR">PKR — Pakistani Rupee (₨)</option>
                                    <option value="PLN">PLN — Polish Zloty (zł)</option>
                                    <option value="QAR">QAR — Qatari Riyal (ر.ق)</option>
                                    <option value="RUB">RUB — Russian Ruble (₽)</option>
                                    <option value="SAR">SAR — Saudi Riyal (ر.س)</option>
                                    <option value="SDG">SDG — Sudanese Pound (ج.س.)</option>
                                    <option value="SEK">SEK — Swedish Krona (kr)</option>
                                    <option value="SGD">SGD — Singapore Dollar (S$)</option>
                                    <option value="SYP">SYP — Syrian Pound (£S)</option>
                                    <option value="THB">THB — Thai Baht (฿)</option>
                                    <option value="TND">TND — Tunisian Dinar (د.ت)</option>
                                    <option value="TRY">TRY — Turkish Lira (₺)</option>
                                    <option value="TWD">TWD — Taiwan Dollar (NT$)</option>
                                    <option value="USD">USD — US Dollar ($)</option>
                                    <option value="VND">VND — Vietnamese Dong (₫)</option>
                                    <option value="YER">YER — Yemeni Rial (﷼)</option>
                                    <option value="ZAR">ZAR — South African Rand (R)</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">VAT Percentage</label>
                                <div class="input-suffix-wrap">
                                    <input type="text" inputmode="decimal" autocomplete="off" class="form-control" id="vatPercentage"
                                           oninput="sanitizeVatPercentage(this)" onkeypress="return isVatPercentageKeyAllowed(event)" onpaste="return isVatPercentagePasteAllowed(event)">
                                    <span class="input-suffix">%</span>
                                </div>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label d-block">VAT Active</label>
                                <div class="d-flex align-items-center p-2" style="height:38px;">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="isVatEnabled" style="width:42px;height:22px;cursor:pointer;" onchange="toggleVatPercentage()">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-image-2-line"></i></div>
                        <div>
                            <div class="settings-card-title">Clinic Logos</div>
                            <div class="settings-card-sub">Where each logo appears across the app</div>
                        </div>
                    </div>
                    <div class="settings-card-body">
                        <div class="d-flex flex-wrap gap-4">
                            <div class="logo-slot">
                                <div class="logo-upload-area" onclick="document.getElementById('iconLogoInput').click()">
                                    <img id="iconLogoPreview">
                                    <i class="ri-image-line" id="iconLogoIcon"></i>
                                    <small>Upload</small>
                                </div>
                                <input type="file" id="iconLogoInput" accept="image/*" style="display:none;" onchange="previewLogo(this, 'iconLogoPreview', 'iconLogoIcon')">
                                <div class="logo-slot-label">Icon Logo</div>
                                <div class="logo-slot-desc">Login &amp; OTP screens and the browser tab icon</div>
                            </div>
                            <div class="logo-slot">
                                <div class="logo-upload-area" onclick="document.getElementById('mainLogoInput').click()">
                                    <img id="mainLogoPreview">
                                    <i class="ri-image-line" id="mainLogoIcon"></i>
                                    <small>Upload</small>
                                </div>
                                <input type="file" id="mainLogoInput" accept="image/*" style="display:none;" onchange="previewLogo(this, 'mainLogoPreview', 'mainLogoIcon')">
                                <div class="logo-slot-label">Logo</div>
                                <div class="logo-slot-desc">Primary logo used generally across the app</div>
                            </div>
                            <div class="logo-slot">
                                <div class="logo-upload-area" onclick="document.getElementById('sidebarLogoInput').click()">
                                    <img id="sidebarLogoPreview">
                                    <i class="ri-image-line" id="sidebarLogoIcon"></i>
                                    <small>Upload</small>
                                </div>
                                <input type="file" id="sidebarLogoInput" accept="image/*" style="display:none;" onchange="previewLogo(this, 'sidebarLogoPreview', 'sidebarLogoIcon')">
                                <div class="logo-slot-label">Sidebar Logo</div>
                                <div class="logo-slot-desc">Shown in the sidebar brand box</div>
                            </div>
                            <div class="logo-slot">
                                <div class="logo-upload-area" onclick="document.getElementById('reportLogoInput').click()">
                                    <img id="reportLogoPreview">
                                    <i class="ri-image-line" id="reportLogoIcon"></i>
                                    <small>Upload</small>
                                </div>
                                <input type="file" id="reportLogoInput" accept="image/*" style="display:none;" onchange="previewLogo(this, 'reportLogoPreview', 'reportLogoIcon')">
                                <div class="logo-slot-label">Report Logo</div>
                                <div class="logo-slot-desc">Printed on invoices and other reports</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-save-bar">
                    <span class="settings-save-hint"><i class="ri-information-line me-1"></i>Changes will apply immediately across all branches.</span>
                    <button type="button" class="btn btn-primary px-4" style="font-weight:700;" onclick="saveSettings()">
                        <i class="ri-save-line me-1"></i> Save Changes
                    </button>
                </div>
            </div>

            <!-- PANEL: Account Setup -->
            <div class="settings-panel" id="panel-accountsetup">
                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-bank-line"></i></div>
                        <div>
                            <div class="settings-card-title">Merchant Bank Account</div>
                            <div class="settings-card-sub">Account details shown to patients for bank transfers</div>
                        </div>
                    </div>
                    <div class="settings-card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Account Holder Name</label>
                                <input type="text" class="form-control" id="merchantAccountHolder">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Bank Name</label>
                                <input type="text" class="form-control" id="merchantBankName">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Account Number</label>
                                <input type="text" inputmode="numeric" autocomplete="off" class="form-control" id="merchantAccountNumber"
                                       onkeypress="return isAccountNumberKeyAllowed(event)" onpaste="return isAccountNumberPasteAllowed(event)">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Branch</label>
                                <input type="text" class="form-control" id="merchantBranch">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">IBAN</label>
                                <input type="text" autocomplete="off" class="form-control" id="merchantIban" maxlength="34"
                                       onkeypress="return isIbanKeyAllowed(event)" onpaste="return isIbanPasteAllowed(event)" oninput="sanitizeIban(this)">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">SWIFT / BIC Code</label>
                                <input type="text" autocomplete="off" class="form-control" id="merchantSwiftCode" maxlength="11"
                                       onkeypress="return isSwiftKeyAllowed(event)" onpaste="return isSwiftPasteAllowed(event)" oninput="sanitizeSwift(this)">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="settings-save-bar">
                    <span class="settings-save-hint"><i class="ri-information-line me-1"></i>Used on invoices and payment instructions.</span>
                    <button type="button" class="btn btn-primary px-4" style="font-weight:700;" onclick="saveMerchantAccount()">
                        <i class="ri-save-line me-1"></i> Save Changes
                    </button>
                </div>

                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-wallet-3-line"></i></div>
                        <div>
                            <div class="settings-card-title">Payment Accounts</div>
                            <div class="settings-card-sub">Cash drawers, mobile money and merchant terminals money is collected into</div>
                        </div>
                        <button type="button" class="btn btn-sm text-white px-3 ms-auto" style="background:#0d9488;border-radius:10px;font-weight:700;" onclick="openPaymentAccountModal()">
                            <i class="ri-add-line me-1"></i> Add Account
                        </button>
                    </div>
                    <div class="settings-card-body">
                        <div class="table-responsive">
                            <table class="table gp-table" id="paymentAccountsDataTable" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>Account Name</th>
                                        <th>Type</th>
                                        <th>Sub Type</th>
                                        <th>Account No</th>
                                        <th>Monthly Budget</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PANEL: Discount Configuration -->
            <div class="settings-panel" id="panel-discounts">
                <div class="settings-card">
                    <div class="settings-card-header">
                        <div class="settings-card-header-icon"><i class="ri-price-tag-3-line"></i></div>
                        <div>
                            <div class="settings-card-title">Discount Configuration</div>
                            <div class="settings-card-sub">Promotions and discount rules applied at checkout</div>
                        </div>
                        <button type="button" class="btn btn-sm text-white px-3 ms-auto" style="background:#0d9488;border-radius:10px;font-weight:700;" onclick="openDiscountModal()">
                            <i class="ri-add-line me-1"></i> Add Discount
                        </button>
                    </div>
                    <div class="settings-card-body">
                        <div class="table-responsive">
                            <table class="table gp-table" id="discountsDataTable" style="width:100%;">
