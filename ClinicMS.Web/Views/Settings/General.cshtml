function saveDiscount() {
    var name = document.getElementById('dName').value.trim();
    var startDate = document.getElementById('dStartDate').value;
    var endDate = document.getElementById('dEndDate').value;
    var value = parseFloat(document.getElementById('dValue').value);

    var isActive = document.getElementById('dActive').checked;

    if (!name) { toastr.error('Discount name is required'); return; }
    if (isNaN(value) || value <= 0) { toastr.error('Enter a valid discount value'); return; }
    if (!startDate || !endDate) { toastr.error('Start and end dates are required'); return; }
    if (endDate < startDate) { toastr.error('End date cannot be before start date'); return; }

    if (isActive) {
        var conflict = discounts.find(function (d) {
            return d.id !== editingDiscountId && d.isActive && startDate <= d.endDate && d.startDate <= endDate;
        });
        if (conflict) {
            toastr.error('"' + escapeHtml(conflict.discountName) + '" is already active from ' + conflict.startDate + ' to ' + conflict.endDate + ', which overlaps this date range.');
            return;
        }
    }

    var body = {
        discountName: name,
        discountType: document.getElementById('dType').value,
        discountValue: value,
        startDate: startDate,
        endDate: endDate,
        isActive: isActive
    };

    var url = editingDiscountId ? '/Settings/UpdateDiscount?id=' + editingDiscountId : '/Settings/CreateDiscount';
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    }).then(function (res) {
        return res.json().then(function (data) { return { ok: res.ok, data: data }; });
    }).then(function (result) {
        if (!result.ok) { toastr.error(result.data.message || 'Could not save discount'); return; }
        if (editingDiscountId) {
            var idx = discounts.findIndex(function (d) { return d.id === editingDiscountId; });
            if (idx >= 0) discounts[idx] = result.data;
        } else {
            discounts.push(result.data);
        }
        toastr.success('Discount saved successfully.', 'Saved');
        bootstrap.Modal.getInstance(document.getElementById('discountModal')).hide();
        refreshDiscountsTable();
    });
}

function deleteDiscount(id) {
    confirmDelete('This discount will be permanently deleted.').then(function (confirmResult) {
