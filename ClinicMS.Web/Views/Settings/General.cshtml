// Only channels with at least one active gateway can be picked for a template -- otherwise it
// could never actually be sent. If a template's own channel later loses its last active gateway,
// it's still added as a (labeled) option so editing it doesn't silently discard the value.
function activeGatewayChannels() {
    var channels = gateways.filter(function (g) { return g.isActive; }).map(function (g) { return g.channelType; });
    return channels.filter(function (c, i) { return channels.indexOf(c) === i; });
}

function populateTemplateChannelOptions(selected) {
    var select = document.getElementById('tplChannelType');
    if (!select) return;
    var channels = activeGatewayChannels();
    var keep = selected || select.value;
    if (keep && channels.indexOf(keep) === -1) {
        select.innerHTML = channels.concat([keep]).map(function (c) {
            return '<option value="' + c + '"' + (c === keep ? ' selected' : '') + '>' + c + (c === keep && activeGatewayChannels().indexOf(c) === -1 ? ' (no active gateway)' : '') + '</option>';
        }).join('');
        return;
    }
    if (!channels.length) {
        select.innerHTML = '<option value="">No active gateway configured</option>';
        return;
    }
    select.innerHTML = channels.map(function (c) { return '<option value="' + c + '">' + c + '</option>'; }).join('');
    if (keep && channels.indexOf(keep) !== -1) select.value = keep;
}

// ── SMS Templates ──
function renderVarTags() {
    var row = document.getElementById('varTagRow');
    if (!row) return;
    row.innerHTML = INSERT_VARIABLES.map(function (v) {
        return '<button type="button" class="btn btn-sm" style="border:1.5px solid #e2e8f0;background:#f8fafc;color:#475569;border-radius:8px;font-weight:700;font-size:.76rem;padding:5px 12px;" onclick="insertVariable(\'' + v + '\')">{' + v + '}</button>';
    }).join('');
}

function insertVariable(name) {
    var textarea = document.getElementById('tplMessage');
    var token = '{' + name + '}';
    var start = textarea.selectionStart != null ? textarea.selectionStart : textarea.value.length;
    var end = textarea.selectionEnd != null ? textarea.selectionEnd : textarea.value.length;
    textarea.value = textarea.value.slice(0, start) + token + textarea.value.slice(end);
    textarea.focus();
    var caret = start + token.length;
    textarea.setSelectionRange(caret, caret);
    onTplMessageInput();
}

function onTplMessageInput() {
    var text = document.getElementById('tplMessage').value;
    var len = text.length;
    document.getElementById('tplCharCount').textContent = len;
    var parts = len === 0 ? 1 : Math.ceil(len / 160);
    document.getElementById('tplSmsParts').textContent = parts + ' SMS';
}

function relativeTime(iso) {
    var date = new Date(iso);
    var startOfDay = function (d) { return new Date(d.getFullYear(), d.getMonth(), d.getDate()); };
    var diffDays = Math.round((startOfDay(new Date()) - startOfDay(date)) / 86400000);
    if (diffDays <= 0) return 'Today';
    if (diffDays === 1) return 'Yesterday';
    return diffDays + ' days ago';
}

function initTemplatesTable() {
    templatesTable = $('#templatesDataTable').DataTable({
        data: templates,
        columns: [
            { data: null, orderable: false, searchable: false, render: function (v, type, row, meta) { return meta.row + 1; } },
            { data: 'templateName', render: function (v, type) { return type === 'display' ? '<span style="font-weight:700;color:#1e293b;">' + escapeHtml(v) + '</span>' : v; } },
            { data: 'channelType', render: function (v) { return '<span class="gp-badge gp-badge-purple">' + v + '</span>'; } },
            {
                data: 'messageBody', render: function (v, type) {
                    var preview = v.length > 70 ? v.slice(0, 70) + '…' : v;
                    return type === 'display' ? '<span style="color:#64748b;">' + escapeHtml(preview) + '</span>' : v;
                }
            },
            { data: 'createdAt', render: function (v) { return relativeTime(v); } },
            {
                data: null, orderable: false, searchable: false, render: function (v, type, row) {
                    return '<div style="display:flex;gap:6px;">'
                        + '<button class="gp-btn-icon" style="background:#f5f3ff;color:#7c3aed;" title="Send" onclick="sendTemplate(' + row.id + ')"><i class="ri-send-plane-line"></i></button>'
                        + '<button class="gp-btn-icon gp-btn-edit" title="Edit" onclick="editTemplate(' + row.id + ')"><i class="ri-pencil-line"></i></button>'
                        + '<button class="gp-btn-icon gp-btn-delete" title="Delete" onclick="deleteTemplate(' + row.id + ')"><i class="ri-delete-bin-line"></i></button>'
                        + '</div>';
                }
            }
        ],
        order: [],
        responsive: true,
        pageLength: 5,
        lengthChange: false,
        dom: "<'d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2'f>t<'d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2'ip>",
        language: { search: '', searchPlaceholder: 'Search templates…', emptyTable: 'No templates saved yet', info: 'Showing _START_–_END_ of _TOTAL_', infoEmpty: 'No templates', infoFiltered: '(filtered from _MAX_)' }
    });
}

function refreshTemplatesTable() {
    templatesTable.clear().rows.add(templates).draw();
}

function editTemplate(id) {
    var t = templates.find(function (x) { return x.id === id; });
    if (!t) return;
    editingTemplateId = id;
    document.getElementById('tplName').value = t.templateName;
    document.getElementById('tplMessage').value = t.messageBody;
    populateTemplateChannelOptions(t.channelType);
    onTplMessageInput();
    document.getElementById('tplFormTitle').textContent = 'Edit Template';
    document.getElementById('tplSaveBtnLabel').textContent = 'Update Template';
    document.getElementById('cancelTplEditBtn').style.display = '';
}

function cancelTemplateEdit() {
    editingTemplateId = null;
    document.getElementById('tplName').value = '';
    document.getElementById('tplMessage').value = '';
    populateTemplateChannelOptions();
    onTplMessageInput();
    document.getElementById('tplFormTitle').textContent = 'New Template';
    document.getElementById('tplSaveBtnLabel').textContent = 'Save Template';
    document.getElementById('cancelTplEditBtn').style.display = 'none';
}

function saveTemplate() {
    var name = document.getElementById('tplName').value.trim();
    var message = document.getElementById('tplMessage').value.trim();
    var channelType = document.getElementById('tplChannelType').value;
    if (!name) { toastr.error('Template name is required'); return; }
    if (!message) { toastr.error('Message content is required'); return; }
    if (!channelType) { toastr.error('Configure an active SMS Gateway channel before creating a template'); return; }

    var body = {
        templateName: name,
        channelType: channelType,
        messageBody: message,
        isActive: true
    };

    var url = editingTemplateId ? '/Settings/UpdateSmsTemplate?id=' + editingTemplateId : '/Settings/CreateSmsTemplate';
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    }).then(function (res) {
        return res.json().then(function (data) { return { ok: res.ok, data: data }; });
    }).then(function (result) {
        if (!result.ok) { toastr.error(result.data.message || 'Could not save template'); return; }
        if (editingTemplateId) {
            var idx = templates.findIndex(function (x) { return x.id === editingTemplateId; });
            if (idx >= 0) templates[idx] = result.data;
        } else {
            templates.unshift(result.data);
        }
        toastr.success('Template saved successfully.', 'Saved');
        cancelTemplateEdit();
        refreshTemplatesTable();
    });
}

function deleteTemplate(id) {
    confirmDelete('This template will be permanently deleted.').then(function (confirmResult) {
        if (!confirmResult.isConfirmed) return;
        fetch('/Settings/DeleteSmsTemplate?id=' + id, { method: 'POST' })
            .then(function (res) {
                return res.json().then(function (data) { return { ok: res.ok, data: data }; });
            })
            .then(function (result) {
                if (!result.ok) { toastr.error(result.data.message || 'Could not delete template'); return; }
                templates = templates.filter(function (t) { return t.id !== id; });
                if (editingTemplateId === id) cancelTemplateEdit();
                deletedAlert('Template deleted.');
                refreshTemplatesTable();
            });
    });
}

function sendTemplate(id) {
    var t = templates.find(function (x) { return x.id === id; });
    if (!t) return;
    toastr.info('Open a patient from Notifications to send "' + t.templateName + '".', 'Send Template');
}

// ── Select2 ──
if (typeof $ !== 'undefined' && $.fn && $.fn.select2) {
    $('select.form-select').select2({ theme: 'default', width: '100%' });
}
</script>
}
