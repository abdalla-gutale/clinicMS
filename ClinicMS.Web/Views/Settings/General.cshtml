@section Scripts {
<script>
var CLINIC_SETTINGS = @Html.Raw(ViewBag.SettingsJson ?? "null");
var MERCHANT_ACCOUNT = @Html.Raw(ViewBag.MerchantAccountJson ?? "null");
var discounts = @Html.Raw(ViewBag.DiscountsJson ?? "[]");
var editingDiscountId = null;
var discountsTable = null;
var paymentAccounts = @Html.Raw(ViewBag.PaymentAccountsJson ?? "[]");
var editingPaymentAccountId = null;
var paymentAccountsTable = null;
var gateways = @Html.Raw(ViewBag.SmsConfigurationsJson ?? "[]");
var editingGatewayId = null;
var templates = @Html.Raw(ViewBag.SmsTemplatesJson ?? "[]");
var editingTemplateId = null;
var templatesTable = null;
var INSERT_VARIABLES = ['name', 'date', 'amount', 'package', 'phone', 'branch', 'invoice'];

// Logo fields are stored relative to the API's own host, so previews use the same
// API-origin-qualified URLs the server already resolved for each logo slot.
var ICON_LOGO_PREVIEW_URL = @Html.Raw(ViewBag.IconLogoPreviewUrl is not null ? $"\"{ViewBag.IconLogoPreviewUrl}\"" : "null");
var LOGO_PREVIEW_URL = @Html.Raw(ViewBag.LogoPreviewUrl is not null ? $"\"{ViewBag.LogoPreviewUrl}\"" : "null");
var SIDEBAR_LOGO_PREVIEW_URL = @Html.Raw(ViewBag.SidebarLogoPreviewUrl is not null ? $"\"{ViewBag.SidebarLogoPreviewUrl}\"" : "null");
var REPORT_LOGO_PREVIEW_URL = @Html.Raw(ViewBag.ReportLogoPreviewUrl is not null ? $"\"{ViewBag.ReportLogoPreviewUrl}\"" : "null");

document.addEventListener('DOMContentLoaded', function () {
    if (CLINIC_SETTINGS) {
        document.getElementById('gymName').value       = CLINIC_SETTINGS.clinicName || '';
        document.getElementById('gymPhone').value      = CLINIC_SETTINGS.phone || '';
        document.getElementById('gymEmail').value      = CLINIC_SETTINGS.email || '';
        document.getElementById('gymAddress').value    = CLINIC_SETTINGS.address || '';
        document.getElementById('currencySymbol').value = CLINIC_SETTINGS.currencySymbol || '';
        document.getElementById('vatPercentage').value  = CLINIC_SETTINGS.vatPercentage || 0;
        document.getElementById('isVatEnabled').checked = !!CLINIC_SETTINGS.isVatEnabled;

        setLogoPreview('iconLogoPreview', 'iconLogoIcon', ICON_LOGO_PREVIEW_URL);
        setLogoPreview('mainLogoPreview', 'mainLogoIcon', LOGO_PREVIEW_URL);
        setLogoPreview('sidebarLogoPreview', 'sidebarLogoIcon', SIDEBAR_LOGO_PREVIEW_URL);
        setLogoPreview('reportLogoPreview', 'reportLogoIcon', REPORT_LOGO_PREVIEW_URL);
    }
    toggleVatPercentage();

    if (MERCHANT_ACCOUNT) {
        document.getElementById('merchantAccountHolder').value = MERCHANT_ACCOUNT.accountHolderName || '';
        document.getElementById('merchantBankName').value      = MERCHANT_ACCOUNT.bankName || '';
        document.getElementById('merchantAccountNumber').value = MERCHANT_ACCOUNT.accountNumber || '';
        document.getElementById('merchantBranch').value        = MERCHANT_ACCOUNT.branch || '';
        document.getElementById('merchantIban').value           = MERCHANT_ACCOUNT.iban || '';
        document.getElementById('merchantSwiftCode').value      = MERCHANT_ACCOUNT.swiftCode || '';
    }

    initDiscountsTable();
    initPaymentAccountsTable();
    renderGatewaysTable();
    initTemplatesTable();
    populateTemplateChannelOptions();
    renderVarTags();
    onTplMessageInput();
});

function setLogoPreview(previewId, iconId, url) {
    if (!url) return;
    document.getElementById(previewId).src = url;
    document.getElementById(previewId).style.display = 'block';
    document.getElementById(iconId).style.display = 'none';
}

function toggleVatPercentage() {
    document.getElementById('vatPercentage').disabled = !document.getElementById('isVatEnabled').checked;
}

// ── VAT percentage input guards: digits + one decimal point only, clamped to [0, 100] ──
var VAT_PERCENTAGE_MAX = 100;

function isVatPercentageKeyAllowed(e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return true;
    var ch = e.key;
    if (ch.length !== 1) return true; // control keys (Backspace, Tab, arrows, etc.)
    if (ch >= '0' && ch <= '9') return true;
    if (ch === '.' && e.target.value.indexOf('.') === -1) return true;
    e.preventDefault();
    return false;
}

function isVatPercentagePasteAllowed(e) {
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^\d*\.?\d*$/.test(text)) { e.preventDefault(); return false; }
    return true;
}

function sanitizeVatPercentage(input) {
    var value = input.value.replace(/[^0-9.]/g, '');
    var firstDot = value.indexOf('.');
    if (firstDot !== -1) {
        value = value.slice(0, firstDot + 1) + value.slice(firstDot + 1).replace(/\./g, '');
    }
    if (value !== '' && value !== '.') {
        var num = parseFloat(value);
        if (!isNaN(num) && num > VAT_PERCENTAGE_MAX) {
            value = String(VAT_PERCENTAGE_MAX);
        }
    }
    input.value = value;
}

// ── Phone: digits + leading "+" and common separators only, no letters ──
function isPhoneKeyAllowed(e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return true;
    var ch = e.key;
    if (ch.length !== 1) return true;
    if (ch >= '0' && ch <= '9') return true;
    if ('+-() '.indexOf(ch) !== -1) return true;
    e.preventDefault();
    return false;
}

function isPhonePasteAllowed(e) {
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^[0-9+\-() ]*$/.test(text)) { e.preventDefault(); return false; }
    return true;
}

function sanitizePhone(input) {
    input.value = input.value.replace(/[^0-9+\-() ]/g, '');
}

// ── Email: strip whitespace as you type; format itself is checked before save ──
function sanitizeEmail(input) {
    input.value = input.value.replace(/\s/g, '');
}

var EMAIL_PATTERN = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

// ── Merchant account number: digits, spaces and dashes only ──
function isAccountNumberKeyAllowed(e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return true;
    var ch = e.key;
    if (ch.length !== 1) return true;
    if (ch >= '0' && ch <= '9') return true;
    if (ch === '-' || ch === ' ') return true;
    e.preventDefault();
    return false;
}

function isAccountNumberPasteAllowed(e) {
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^[0-9\- ]*$/.test(text)) { e.preventDefault(); return false; }
    return true;
}

// ── IBAN: letters, digits and spaces only, auto-uppercased ──
function isIbanKeyAllowed(e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return true;
    var ch = e.key;
    if (ch.length !== 1) return true;
    if (/[a-zA-Z0-9 ]/.test(ch)) return true;
    e.preventDefault();
    return false;
}

function isIbanPasteAllowed(e) {
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^[a-zA-Z0-9 ]*$/.test(text)) { e.preventDefault(); return false; }
    return true;
}

function sanitizeIban(input) {
    input.value = input.value.toUpperCase();
}

// ── SWIFT/BIC: letters and digits only (no spaces), auto-uppercased ──
function isSwiftKeyAllowed(e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return true;
    var ch = e.key;
    if (ch.length !== 1) return true;
    if (/[a-zA-Z0-9]/.test(ch)) return true;
    e.preventDefault();
    return false;
}

function isSwiftPasteAllowed(e) {
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^[a-zA-Z0-9]*$/.test(text)) { e.preventDefault(); return false; }
    return true;
}

function sanitizeSwift(input) {
    input.value = input.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
}

// ── Tab switching ── (nav items with no data-panel, e.g. SMS Templates, are real links to
// their own page and navigate normally instead of switching an in-page panel)
document.querySelectorAll('.settings-nav-item').forEach(function(item) {
    item.addEventListener('click', function(e) {
        if (!item.dataset.panel) return;
        e.preventDefault();
        document.querySelectorAll('.settings-nav-item').forEach(function(i) { i.classList.remove('active'); });
        document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });
        item.classList.add('active');
        var panel = document.getElementById('panel-' + item.dataset.panel);
        if (panel) panel.classList.add('active');
    });
});

// ── Logo preview ──
function previewLogo(input, previewId, iconId) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            setLogoPreview(previewId, iconId, e.target.result);
        };
        reader.readAsDataURL(input.files[0]);
    }
}

// ── Save ──
function saveSettings() {
    var activePanel = document.querySelector('.settings-panel.active');
    if (!activePanel || activePanel.id !== 'panel-gym') {
        if (typeof toastr !== 'undefined') toastr.info('This section is not yet connected to a saved setting.', 'Not available');
        return;
    }

    // Logo previews are local-only (no upload endpoint yet) -- uploaded files aren't persisted,
    // so the previously saved logo URLs round-trip unchanged.
    var body = {
        clinicName: document.getElementById('gymName').value.trim(),
        logoIconUrl: CLINIC_SETTINGS ? CLINIC_SETTINGS.logoIconUrl : null,
        logoUrl: CLINIC_SETTINGS ? CLINIC_SETTINGS.logoUrl : null,
        sidebarLogoUrl: CLINIC_SETTINGS ? CLINIC_SETTINGS.sidebarLogoUrl : null,
        reportLogoUrl: CLINIC_SETTINGS ? CLINIC_SETTINGS.reportLogoUrl : null,
        phone: document.getElementById('gymPhone').value.trim() || null,
        email: document.getElementById('gymEmail').value.trim() || null,
        address: document.getElementById('gymAddress').value.trim() || null,
        vatPercentage: Math.min(parseFloat(document.getElementById('vatPercentage').value) || 0, VAT_PERCENTAGE_MAX),
        isVatEnabled: document.getElementById('isVatEnabled').checked,
        currencySymbol: document.getElementById('currencySymbol').value || 'AED'
    };

    if (!body.clinicName) { toastr.error('Clinic name is required'); return; }
