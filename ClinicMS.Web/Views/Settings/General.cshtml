// Status is derived from the date range rather than stored, so it always reflects "today":
// Inactive (manually turned off) > Closed (end date passed) > Scheduled (not started yet) > Open.
function discountStatusBadge(d) {
    var today = new Date().toISOString().slice(0, 10);
    if (!d.isActive) return '<span class="gp-badge gp-badge-gray">Inactive</span>';
    if (d.endDate < today) return '<span class="gp-badge gp-badge-gray">Closed</span>';
    if (d.startDate > today) return '<span class="gp-badge gp-badge-yellow">Scheduled</span>';
    return '<span class="gp-badge gp-badge-green">Open</span>';
}

