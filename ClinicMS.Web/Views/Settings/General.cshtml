// Master Card is always a plain card number; Cash/Merchant only need a number when tied to a
// mobile-money carrier (Account Type Sub != None) so the payment can be traced to a real wallet.
function onPaymentAccountTypeChange() {
    var type = document.getElementById('paType').value;
    var subGroup = document.getElementById('paTypeSubGroup');
    var subField = document.getElementById('paTypeSub');
    var numberField = document.getElementById('paNumber');
    var label = document.getElementById('paNumberLabel');

    if (type === 'MasterCard') {
        subGroup.style.display = 'none';
        subField.value = 'None';
        numberField.disabled = false;
        numberField.placeholder = 'Card number';
        label.textContent = 'Account No';
        label.classList.add('required');
    } else {
        subGroup.style.display = '';
        updatePaymentAccountNumberRequirement();
    }
}

function updatePaymentAccountNumberRequirement() {
    var type = document.getElementById('paType').value;
    if (type === 'MasterCard') return;
    var sub = document.getElementById('paTypeSub').value;
    var numberField = document.getElementById('paNumber');
    var label = document.getElementById('paNumberLabel');
    if (sub === 'None') {
        numberField.placeholder = 'Not required for a plain Cash/Merchant account';
        label.classList.remove('required');
    } else {
        numberField.placeholder = sub === 'Somtel' || sub === 'Evc' || sub === 'Zaad' ? 'e.g. +252-61-234-5678' : 'Account No';
        label.classList.add('required');
    }
}
