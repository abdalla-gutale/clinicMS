@using ClinicMS.Web.Models.Api.Auth
@using ClinicMS.Web.Services.Api
@{
    // Session-based auth, not cookie/claims auth -- there's no authentication middleware in
    // Program.cs, so Context.User is always an empty anonymous principal. The logged-in user's
    // identity lives in SessionKeys.AuthUser (set by AccountController.VerifyOtp) instead.
    UserSummary? authUser = null;
    var authJson = Context?.Session.GetString(SessionKeys.AuthUser);
    if (!string.IsNullOrEmpty(authJson))
    {
        authUser = System.Text.Json.JsonSerializer.Deserialize<UserSummary>(authJson);
    }

    var fullName = authUser?.FullName ?? "User";
    var firstName = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "User";
    var role = authUser?.RoleName ?? "User";
    var avatarLetter = firstName.Substring(0, 1).ToUpperInvariant();
}

<style>
/* ══════════════════════════════════════
   TOPBAR — REDESIGN
══════════════════════════════════════ */
#page-topbar {
    background: #ffffff !important;
    border-bottom: 1px solid #e9ecef !important;
    box-shadow: 0 2px 12px rgba(15,23,42,.06) !important;
}

/* divider */
.tb-divider { width: 1px; height: 24px; background: #e2e8f0; flex-shrink: 0; }

/* user chip */
.tb-user-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 5px 14px 5px 6px;
    border-radius: 12px;
    border: 1.5px solid #e2e8f0;
    background: #f8fafc;
    cursor: pointer;
    transition: all .16s;
    flex-shrink: 0;
}
.tb-user-btn:hover { border-color: #0d9488; background: #f0fdfa; }
.tb-user-avatar {
    width: 30px; height: 30px; border-radius: 8px;
    background: linear-gradient(135deg, #0d9488, #0891b2);
    color: #fff; font-size: .8rem; font-weight: 800;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.tb-user-name { font-size: .82rem; font-weight: 700; color: #1e293b; }
.tb-user-role { font-size: .7rem; color: #94a3b8; line-height: 1; margin-top: 1px; }
.tb-user-chevron { color: #94a3b8; font-size: .78rem; margin-left: 2px; }

/* breadcrumb row */
.tb-breadcrumb-bar {
    background: #f8fafc;
    border-bottom: 1px solid #f1f5f9;
    padding: 7px 24px;
    display: flex; align-items: center; justify-content: space-between;
}
.tb-page-title { font-size: .82rem; font-weight: 800; color: #1e293b; text-transform: uppercase; letter-spacing: .06em; }
.tb-breadcrumb { display: flex; align-items: center; gap: 6px; font-size: .78rem; color: #94a3b8; }
.tb-breadcrumb a { color: #64748b; text-decoration: none; font-weight: 600; }
.tb-breadcrumb a:hover { color: #0d9488; }
.tb-breadcrumb-sep { color: #cbd5e1; font-size: .7rem; }

@@media (max-width: 768px) {
    .tb-user-name, .tb-user-role { display: none; }
    .tb-lang-label { display: none; }
}
</style>

<header id="page-topbar">
    <div class="layout-width">
        <div class="navbar-header" style="padding: 0 24px; height: 60px; display:flex; align-items:center; gap:12px;">

            <!-- Hamburger (mobile) -->
            <button type="button"
                    class="btn btn-sm px-2 fs-16 header-item vertical-menu-btn topnav-hamburger shadow-none d-lg-none"
                    id="topnav-hamburger-icon"
                    style="border:none;background:transparent;color:#64748b;flex-shrink:0;">
                <span class="hamburger-icon"><span></span><span></span><span></span></span>
            </button>

            <!-- Right actions -->
            <div class="d-flex align-items-center gap-2 ms-auto flex-nowrap">

                <div class="tb-divider d-none d-sm-block"></div>

                <!-- User -->
                <div class="dropdown">
                    <button class="tb-user-btn shadow-none border-0 p-0" id="page-header-user-dropdown"
                            data-bs-toggle="dropdown" aria-expanded="false"
                            style="border:1.5px solid #e2e8f0 !important;background:#f8fafc !important;padding:5px 14px 5px 6px !important;border-radius:12px !important;">
                        <span class="tb-user-avatar">@avatarLetter</span>
                        <span class="d-none d-xl-flex flex-column align-items-start">
                            <span class="tb-user-name">@firstName</span>
                            <span class="tb-user-role">@role</span>
                        </span>
                        <i class="ri-arrow-down-s-line tb-user-chevron d-none d-xl-inline"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end"
                         style="min-width:200px;border-radius:16px;border:1px solid #e2e8f0;box-shadow:0 12px 32px rgba(15,23,42,.12);padding:8px;">
                        <div style="padding:10px 14px 8px;border-bottom:1px solid #f1f5f9;margin-bottom:6px;">
                            <div style="font-size:.82rem;font-weight:800;color:#1e293b;">@firstName</div>
                            <div style="font-size:.72rem;color:#94a3b8;">@role</div>
                        </div>
                        <a class="dropdown-item rounded-2 py-2" href="/Account/Profile">
                            <i class="ri-user-line me-2 text-muted"></i> Profile
                        </a>
                        <div style="height:1px;background:#f1f5f9;margin:6px 0;"></div>
                        <form method="post" action="/Account/Logout" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item rounded-2 py-2 text-danger border-0 bg-transparent w-100 text-start">
                                <i class="ri-logout-box-r-line me-2"></i> Logout
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</header>
